---
// Aviso profesional sobre la variación del color en pantalla. Rojo de marca,
// legible, integrado con gusto (filete rojo a la izquierda), sin alarmismo.
// `variant`: 'full' (con encabezado) | 'inline' (compacto de una línea).
interface Props {
  variant?: 'full' | 'inline';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;
---

{
  variant === 'inline' ? (
    <p class={`border-l-2 border-rojo pl-3 text-[12.5px] leading-relaxed text-papel/70 ${className}`}>
      <span class="font-semibold text-rojo-400">El color en pantalla es orientativo.</span>{' '}
      Para acertar, ven con una muestra real o consulta la carta física en tienda.
    </p>
  ) : (
    <div class={`flex gap-3.5 rounded-r-xl border-l-2 border-rojo bg-white/[0.03] py-4 pr-5 pl-4 ${className}`}>
      <p class="text-[13px] leading-relaxed text-papel/85">
        <span class="font-semibold tracking-wide text-rojo-400">Importante.</span>{' '}
        El color que ves en pantalla es orientativo: cada dispositivo, brillo y
        luz alteran el tono real. Para igualar un color con precisión, la
        referencia válida es la carta física o una muestra real vista en tienda.
        Te asesoramos según soporte, uso y acabado.
      </p>
    </div>
  )
}
