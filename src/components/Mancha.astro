---
// Mancha de pintura decorativa REAL: siluetas de salpicaduras auténticas
// (PNG de Pixabay teñidos a los colores de marca, ver CREDITS-IMAGENES.md).
// Se coloca en absoluto dentro de una sección con `relative overflow-hidden`.
import { asset } from '../lib/asset';

interface Props {
  // 1-3: salpicaduras con spray · 4: mancha grande de borde · 5: mancha estrella sólida
  forma?: 1 | 2 | 3 | 4 | 5;
  color?: 'rojo' | 'azul' | 'albero' | 'blanco' | 'negro';
  class?: string; // posicionamiento + tamaño + opacidad
  rotar?: number;
}
const { forma = 1, color = 'rojo', class: className = '', rotar = 0 } = Astro.props;
---

<img
  src={asset(`/assets/manchas/splat${forma}-${color}.png`)}
  alt=""
  aria-hidden="true"
  class={`mancha ${className}`}
  style={`transform: rotate(${rotar}deg);`}
  loading="lazy"
/>
