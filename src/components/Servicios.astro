---
import { servicios } from '../data/site';
import Mancha from './Mancha.astro';
---

<section id="servicios" class="relative overflow-hidden bg-negro py-16 text-papel md:py-24">
  <Mancha color="albero" forma={1} class="top-8 -right-20 w-60 opacity-[0.12] md:w-72" rotar={100} />
  <div class="container-x">
    <div class="reveal max-w-xl">
      <p class="kicker-brocha text-rojo">Por qué Euronova</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Lo que no te da<br />una gran superficie.
      </h2>
    </div>

    <div class="mt-12 grid gap-x-10 gap-y-10 sm:grid-cols-2">
      {
        servicios.map((s) => (
          <div class="reveal border-t border-white/15 pt-5">
            <div class="flex items-baseline gap-4">
              <span class="font-display text-[15px] font-bold text-rojo">{s.num}</span>
              <h3 class="font-display text-xl font-bold text-white">{s.nombre}</h3>
            </div>
            <p class="mt-2.5 pl-10 text-[14px] leading-relaxed text-papel/70">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
