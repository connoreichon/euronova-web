---
import { servicios } from '../data/site';
---

<section id="servicios" class="py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="reveal max-w-xl">
      <p class="kicker-brocha text-rojo">Por qué Euronova</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Lo que no te da<br class="hidden sm:block" />una gran superficie.
      </h2>
    </div>

    <div class="mt-12 grid gap-x-10 gap-y-10 sm:grid-cols-2">
      {
        servicios.map((s) => (
          <div class="reveal grid grid-cols-[auto_1fr] items-start gap-x-5 border-t border-white/15 pt-5">
            <span class="font-display text-4xl leading-none font-bold text-rojo/35 md:text-5xl">{s.num}</span>
            <div>
              <h3 class="font-display text-xl font-bold text-white">{s.nombre}</h3>
              <p class="mt-2 text-[14px] leading-relaxed text-papel/72">{s.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
