---
import { site } from '../data/site';
import LogoEuronova from './LogoEuronova.astro';
import { asset } from '../lib/asset';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
// Rutas absolutas con base: funcionan desde la portada y desde /cartas
const enlaces = [
  { href: asset('/') + '#productos', txt: 'Productos' },
  { href: asset('/') + '#color', txt: 'Color a medida' },
  { href: asset('/cartas/'), txt: 'Cartas de colores' },
  { href: asset('/') + '#marcas', txt: 'Marcas' },
  { href: asset('/') + '#tienda', txt: 'Tienda' }
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-colors duration-300"
>
  <div class="container-x flex items-center justify-between gap-3 py-3.5">
    <a href={asset('/') + '#top'} aria-label={site.nombre} class="block">
      <LogoEuronova variant="compact" class="h-7 w-auto md:h-8" />
    </a>

    <nav aria-label="Secciones" class="hidden items-center gap-6 md:flex">
      {
        enlaces.map((e) => (
          <a
            href={e.href}
            class="text-[13px] font-medium text-white/85 transition-colors hover:text-white"
          >
            {e.txt}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`tel:${site.telefonoLink}`}
        class="hidden rounded-full border border-white/40 px-4 py-2 text-[13px] font-semibold text-white transition-colors hover:border-white sm:block"
        aria-label={`Llamar al ${site.telefono}`}
      >
        {site.telefono}
      </a>
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 rounded-full bg-wasap px-4 py-2 text-[13px] font-bold text-white shadow-sm transition-transform hover:-translate-y-0.5"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.5a1.8 1.8 0 0 0 .3-.4.4.4 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.1 5 5 0 0 0 1.1 2.7 11.5 11.5 0 0 0 4.4 3.9 14.6 14.6 0 0 0 1.5.5 3.5 3.5 0 0 0 1.6.1 2.6 2.6 0 0 0 1.7-1.2 2.1 2.1 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z"
          />
        </svg>
        WhatsApp
      </a>
    </div>
  </div>

  <!-- Navegación móvil: fila deslizable compacta (los links de desktop van ocultos) -->
  <nav
    aria-label="Secciones (móvil)"
    class="container-x sin-scrollbar -mt-1 flex gap-5 overflow-x-auto pb-2.5 whitespace-nowrap md:hidden"
  >
    {
      enlaces.map((e) => (
        <a href={e.href} class="text-[12px] font-medium text-white/80 transition-colors hover:text-white">
          {e.txt}
        </a>
      ))
    }
  </nav>
</header>

<script>
  // Arriba: transparente sobre el hero rojo. Con scroll: barra roja sólida.
  const header = document.getElementById('site-header');
  const aplicar = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.classList.add('bg-rojo/95', 'shadow-lg', 'shadow-rojo-900/20', 'backdrop-blur');
    } else {
      header.classList.remove('bg-rojo/95', 'shadow-lg', 'shadow-rojo-900/20', 'backdrop-blur');
    }
  };
  aplicar();
  addEventListener('scroll', aplicar, { passive: true });
</script>
