---
// Cierre comercial: refuerza la tienda física y el criterio profesional.
// Sin "mándanos una foto" — la referencia es la muestra real y la carta física.
import { site } from '../data/site';
---

<section class="bg-rojo py-16 text-white md:py-20">
  <div class="container-x flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
    <div class="reveal max-w-xl">
      <h2 class="display text-3xl text-white md:text-4xl">Para acertar con el color, mejor en persona.</h2>
      <p class="mt-3 text-[15px] leading-relaxed text-white/85">
        Ven con una muestra real y te asesoramos con la carta física y criterio
        profesional. Elegimos juntos el producto, el acabado y el tono exactos —
        no a ojo.
      </p>
    </div>
    <div class="reveal flex flex-wrap items-center gap-3">
      <a
        href={site.mapsLink}
        target="_blank"
        rel="noopener"
        class="rounded-full bg-white px-6 py-3 text-[14px] font-bold text-rojo transition-transform hover:-translate-y-0.5"
      >
        Cómo llegar
      </a>
      <a
        href={`tel:${site.telefonoLink}`}
        class="rounded-full border border-white/50 px-6 py-3 text-[14px] font-semibold text-white transition-colors hover:border-white hover:bg-white/10"
      >
        {site.telefono}
      </a>
    </div>
  </div>
</section>
