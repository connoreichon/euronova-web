---
// Cierre comercial: refuerza la tienda física y el criterio profesional.
// Sin "mándanos una foto" — la referencia es la muestra real y la carta física.
import { site } from '../data/site';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<section class="seccion-roja py-16 text-white md:py-24">
  <div class="container-x flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
    <div class="reveal max-w-xl">
      <h2 class="display text-3xl text-white md:text-5xl">Para acertar con el color, mejor en persona.</h2>
      <p class="mt-3 text-[15px] leading-relaxed text-white">
        Ven con una muestra real y te asesoramos con la carta física y criterio
        profesional. Elegimos juntos el producto, el acabado y el tono exactos —
        no a ojo.
      </p>
    </div>
    <div class="reveal flex flex-wrap items-center gap-3">
      <a
        href={site.mapsLink}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-[14px] font-bold text-rojo transition-transform hover:-translate-y-0.5"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
          <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" stroke-linejoin="round" />
          <circle cx="12" cy="10" r="2.6" />
        </svg>
        Cómo llegar a la tienda
      </a>
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full border border-white/60 px-6 py-3 text-[14px] font-semibold text-white transition-colors hover:border-white hover:bg-white/10"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.5a1.8 1.8 0 0 0 .3-.4.4.4 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.1 5 5 0 0 0 1.1 2.7 11.5 11.5 0 0 0 4.4 3.9 14.6 14.6 0 0 0 1.5.5 3.5 3.5 0 0 0 1.6.1 2.6 2.6 0 0 0 1.7-1.2 2.1 2.1 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z" /></svg>
        Consúltanos por WhatsApp
      </a>
    </div>
  </div>
</section>

<!-- Goteo rojo hacia el footer: rima el cierre con la apertura del hero -->
<svg class="drip-divider text-rojo" viewBox="0 0 1200 34" preserveAspectRatio="none" aria-hidden="true">
  <path
    fill="currentColor"
    d="M0 0h1200v6h-140q-8 22-16 0H840q-9 28-18 0H620q-7 18-14 0H380q-9 24-18 0H160q-7 16-14 0H0Z"
  ></path>
</svg>
