---
// Cierre comercial (Fase 4 del MASTER, §28): momento de marca en rojo,
// compacto y directo. Una pregunta, dos salidas: WhatsApp o tienda.
import { site } from '../data/site';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
  'Hola, no sé qué pintura necesito. Os mando una foto:'
)}`;
---

<section class="bg-rojo py-16 text-white md:py-20">
  <div class="container-x flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
    <div class="reveal">
      <h2 class="display text-3xl text-white md:text-4xl">¿No sabes qué pintura necesitas?</h2>
      <p class="mt-3 max-w-md text-[15px] leading-relaxed text-white/85">
        Mándanos una foto por WhatsApp o pásate por la tienda y te ayudamos a
        elegir acabado, color y producto.
      </p>
    </div>
    <div class="reveal flex flex-wrap items-center gap-3">
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full bg-wasap px-6 py-3 text-[14px] font-bold text-white transition-transform hover:-translate-y-0.5"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.5a1.8 1.8 0 0 0 .3-.4.4.4 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.1 5 5 0 0 0 1.1 2.7 11.5 11.5 0 0 0 4.4 3.9 14.6 14.6 0 0 0 1.5.5 3.5 3.5 0 0 0 1.6.1 2.6 2.6 0 0 0 1.7-1.2 2.1 2.1 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z"
          />
        </svg>
        Mándanos una foto
      </a>
      <a
        href={`tel:${site.telefonoLink}`}
        class="rounded-full border border-white/50 px-6 py-3 text-[14px] font-semibold text-white transition-colors hover:border-white hover:bg-white/10"
      >
        {site.telefono}
      </a>
    </div>
  </div>
</section>
