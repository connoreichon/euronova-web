---
// HERO principal (rediseño quirúrgico): rojo ATMOSFÉRICO —capas de luz,
// pigmento sutil y viñeta— con jerarquía editorial: eyebrow → H1 que vende →
// copy de mostrador → 2 CTAs → banda de confianza. El logo vive en la
// navegación; aquí manda el titular. La foto se trata como pieza hero (losa
// granate desplazada + chip de "color a medida"), no como card.
import { site } from '../data/site';
import { asset } from '../lib/asset';
---

<section id="top" class="hero-fondo pt-28 pb-20 text-white md:pt-36 md:pb-24">
  <div class="container-x grid items-center gap-14 md:grid-cols-[1.06fr_1fr] lg:gap-16">
    <!-- Columna de contenido -->
    <div class="hero-anim">
      <p class="kicker text-white/85">{site.nombre} · Las Lagunas de Mijas</p>
      <h1 class="display mt-4 max-w-[21ch] text-[clamp(2.4rem,4.4vw,3.9rem)] leading-[1.04] text-white">
        Color a medida y asesoramiento experto para pintar sin fallar.
      </h1>
      <p class="mt-5 max-w-[560px] text-[15.5px] leading-relaxed text-white/95">
        Te ayudamos a elegir la pintura adecuada según superficie, uso, acabado
        y color. En tienda, con carta física, muestra real y experiencia de
        mostrador.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={site.mapsLink}
          target="_blank"
          rel="noopener"
          class="rounded-full bg-white px-7 py-3.5 text-[14.5px] font-bold text-rojo-700 shadow-[0_10px_24px_-12px_rgba(60,8,10,0.8)] transition-all hover:-translate-y-0.5 hover:shadow-[0_14px_30px_-12px_rgba(60,8,10,0.9)]"
        >
          Cómo llegar a la tienda
        </a>
        <a
          href={asset('/cartas/')}
          class="rounded-full border border-white/55 px-7 py-3.5 text-[14.5px] font-semibold text-white transition-colors hover:border-white hover:bg-white/10"
        >
          Ver cartas de colores
        </a>
      </div>
      <!-- Aviso de color: panel CLARO (no rojo sobre rojo), acento de muestra -->
      <div class="mt-5 flex max-w-[520px] items-center gap-3 rounded-xl border border-white/20 bg-white/[0.12] px-4 py-3 backdrop-blur-sm">
        <span class="flex shrink-0 gap-0.5" aria-hidden="true">
          <span class="h-6 w-2.5 rounded-[2px] bg-[#f2e9d8]"></span>
          <span class="h-6 w-2.5 rounded-[2px] bg-[#d9a441]"></span>
        </span>
        <p class="text-[12.5px] leading-snug text-white">
          <span class="font-semibold">El color en pantalla es orientativo.</span>{' '}
          Para acertar, ven con una muestra real o consulta la carta física en tienda.
        </p>
      </div>

      <!-- Confianza: tira de "muestras" (cuadrado de color + dato) -->
      <div class="mt-9 flex flex-wrap items-center gap-2.5 border-t border-white/20 pt-5">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3.5 py-1.5 text-[12.5px] font-semibold text-white ring-1 ring-white/15 backdrop-blur-sm">
          <span class="h-2.5 w-2.5 shrink-0 rounded-[2px] bg-[#f2e9d8]" aria-hidden="true"></span>
          +<span data-count="20">20</span> años asesorando
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3.5 py-1.5 text-[12.5px] font-semibold text-white ring-1 ring-white/15 backdrop-blur-sm">
          <span class="h-2.5 w-2.5 shrink-0 rounded-[2px] bg-[#d9a441]" aria-hidden="true"></span>
          Color a medida en tienda
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3.5 py-1.5 text-[12.5px] font-semibold text-white ring-1 ring-white/15 backdrop-blur-sm">
          <span class="h-2.5 w-2.5 shrink-0 rounded-[2px] bg-[#2a5cad]" aria-hidden="true"></span>
          Particulares y profesionales
        </span>
      </div>
    </div>

    <!-- Pieza visual: fachada real con marco editorial + detalle de color -->
    <div class="parallax relative mt-2 md:mt-0" data-parallax="0.05">
      <div class="hero-marco relative">
        <div class="hero-foto overflow-hidden rounded-3xl ring-1 ring-white/20 shadow-[0_34px_70px_-28px_rgba(60,8,10,0.7)]">
          <img
            src={asset('/assets/img/categorias/fachadas.jpg')}
            alt="Fachada mediterránea recién pintada en tonos claros con carpintería azul"
            class="aspect-[4/3] w-full object-cover md:aspect-[5/4]"
            width="1280"
            height="853"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <!-- Detalle único: muestra de color mezclado en tienda -->
        <div class="absolute -bottom-5 left-5 flex items-center gap-2.5 rounded-xl bg-white/95 py-2.5 pr-4 pl-2.5 shadow-lg shadow-rojo-900/35 backdrop-blur-sm">
          <span class="flex gap-1" aria-hidden="true">
            <span class="h-8 w-3.5 rounded-[3px]" style="background:#f2e9d8"></span>
            <span class="h-8 w-3.5 rounded-[3px]" style="background:#d9a441"></span>
            <span class="h-8 w-3.5 rounded-[3px]" style="background:#2a5cad"></span>
          </span>
          <span class="text-[12px] leading-tight font-bold text-negro">
            Color a medida
            <span class="block text-[11px] font-medium text-negro/60">mezclado en tienda</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Goteo de pintura roja hacia la sección siguiente -->
<svg
  class="drip-divider text-rojo"
  viewBox="0 0 1200 34"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    fill="currentColor"
    d="M0 0h1200v6h-140q-8 22-16 0H840q-9 28-18 0H620q-7 18-14 0H380q-9 24-18 0H160q-7 16-14 0H0Z"
  ></path>
</svg>
