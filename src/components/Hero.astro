---
import { site, categorias } from '../data/site';
import { asset } from '../lib/asset';
import LogoEuronova from './LogoEuronova.astro';
import Mancha from './Mancha.astro';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<section id="top" class="relative bg-rojo pt-24 pb-14 text-white md:pt-32 md:pb-16">
  <div class="container-x grid items-center gap-12 md:grid-cols-[1.3fr_1fr]">
    <div>
      <h1 class="sr-only">{site.nombre} — {site.reclamo}</h1>
      <LogoEuronova class="w-full max-w-2xl" />
      <p class="mt-5 max-w-md text-[15px] leading-relaxed text-white/85">
        {site.subtituloHero}
      </p>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-wasap px-6 py-3.5 text-[14px] font-bold text-white shadow-xl shadow-rojo-900/30 transition-transform hover:scale-[1.04]"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.5a1.8 1.8 0 0 0 .3-.4.4.4 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.1 5 5 0 0 0 1.1 2.7 11.5 11.5 0 0 0 4.4 3.9 14.6 14.6 0 0 0 1.5.5 3.5 3.5 0 0 0 1.6.1 2.6 2.6 0 0 0 1.7-1.2 2.1 2.1 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z"
            />
          </svg>
          Escríbenos por WhatsApp
        </a>
        <a
          href={site.mapsLink}
          target="_blank"
          rel="noopener"
          class="rounded-full border-[1.5px] border-white/50 px-6 py-3.5 text-[14px] font-semibold text-white transition-colors hover:border-white hover:bg-white/10"
        >
          Cómo llegar
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        {
          categorias.slice(0, 4).map((c) => (
            <a
              href="#productos"
              class="rounded-full bg-white/14 px-3.5 py-1.5 text-[12px] font-medium text-white transition-colors hover:bg-white/25"
            >
              {c.nombre}
            </a>
          ))
        }
        <a
          href="#color"
          class="rounded-full bg-white px-3.5 py-1.5 text-[12px] font-bold text-rojo transition-transform hover:scale-105"
        >
          Color a medida
        </a>
      </div>
    </div>

    <!-- Manchas de pintura negra (decoración, "mancharse es parte del oficio") -->
    <div class="relative hidden min-h-72 md:block" aria-hidden="true">
      <Mancha color="negro" forma={5} class="top-1/2 left-1/2 w-72 -translate-x-1/2 -translate-y-1/2 opacity-90" rotar={-14} />
      <Mancha color="negro" forma={5} class="top-6 right-2 w-24 opacity-70" rotar={48} />
      <Mancha color="negro" forma={5} class="bottom-4 left-4 w-16 opacity-60" rotar={160} />
    </div>
  </div>
</section>

<!-- Goteo de pintura roja hacia la sección siguiente -->
<svg
  class="drip-divider text-rojo"
  viewBox="0 0 1200 34"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    fill="currentColor"
    d="M0 0h1200v6h-140q-8 22-16 0H840q-9 28-18 0H620q-7 18-14 0H380q-9 24-18 0H160q-7 16-14 0H0Z"
  ></path>
</svg>
