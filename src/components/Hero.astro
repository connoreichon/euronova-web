---
// Hero (Fase 2 del MASTER): franja de marca roja CONTROLADA — logo
// proporcionado, propuesta comercial explícita, foto protagonista a la
// derecha y solo dos CTAs. Nada de masa roja a pantalla completa.
import { site } from '../data/site';
import { asset } from '../lib/asset';
import LogoEuronova from './LogoEuronova.astro';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<section id="top" class="relative bg-rojo pt-28 pb-16 text-white md:pt-32 md:pb-20">
  <div class="container-x grid items-center gap-12 md:grid-cols-[1.15fr_1fr]">
    <div class="hero-anim">
      <h1 class="sr-only">{site.nombre} — {site.reclamo}</h1>
      <LogoEuronova class="w-full max-w-md" />
      <p class="font-display mt-8 max-w-lg text-xl leading-snug font-bold text-white md:text-2xl">
        Pinturas, color a medida y asesoramiento en Las Lagunas de Mijas.
      </p>
      <p class="mt-3 max-w-md text-[15px] leading-relaxed text-white">
        Dinos qué vas a pintar y te ayudamos a elegir el producto, el acabado
        y el color adecuado.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={site.mapsLink}
          target="_blank"
          rel="noopener"
          class="rounded-full bg-white px-6 py-3 text-[14px] font-bold text-rojo transition-transform hover:-translate-y-0.5"
        >
          Cómo llegar a la tienda
        </a>
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full border border-white/60 px-6 py-3 text-[14px] font-semibold text-white transition-colors hover:border-white hover:bg-white/10"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.5a1.8 1.8 0 0 0 .3-.4.4.4 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.1 5 5 0 0 0 1.1 2.7 11.5 11.5 0 0 0 4.4 3.9 14.6 14.6 0 0 0 1.5.5 3.5 3.5 0 0 0 1.6.1 2.6 2.6 0 0 0 1.7-1.2 2.1 2.1 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z" /></svg>
          Escríbenos por WhatsApp
        </a>
        <a
          href={asset('/cartas/')}
          class="inline-flex items-center gap-1.5 py-3 text-[13px] font-semibold text-white underline-offset-4 hover:underline"
        >
          Ver cartas de colores
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
      </div>

      <p class="mt-8 text-[13px] tracking-wide text-white">
        +<span data-count="20">20</span> años · Tienda física en Las Lagunas · Color a medida al momento
      </p>
    </div>

    <!-- Foto protagonista: resultado real, contrapunto luminoso al rojo -->
    <div class="mt-8 md:mt-0">
      <div class="reveal-img overflow-hidden rounded-2xl shadow-lg shadow-rojo-900/40">
        <img
          src={asset('/assets/img/categorias/fachadas.jpg')}
          alt="Fachada mediterránea recién pintada en tonos claros con carpintería azul"
          class="aspect-[4/3] w-full object-cover"
          width="1280"
          height="853"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<!-- Goteo de pintura roja hacia la sección siguiente -->
<svg
  class="drip-divider text-rojo"
  viewBox="0 0 1200 34"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    fill="currentColor"
    d="M0 0h1200v6h-140q-8 22-16 0H840q-9 28-18 0H620q-7 18-14 0H380q-9 24-18 0H160q-7 16-14 0H0Z"
  ></path>
</svg>
