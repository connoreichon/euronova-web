---
// Muro de marcas: sección CLARA (papel/crema) para descansar del rojo. Solo
// logos/wordmarks, sin enlaces externos ni descripciones. Data-driven (site.ts).
// Mientras no haya logos, cada tile muestra el nombre como wordmark; al rellenar
// `logo` en site.ts se pinta la imagen (mismo tile, misma altura visual).
import { marcas } from '../data/site';
import { asset } from '../lib/asset';
---

<section id="marcas" class="paint-surface paint-surface--paper py-20 md:py-28">
  <div class="container-x">
    <div class="reveal max-w-2xl">
      <p class="kicker-brocha kicker-brocha--sm text-rojo">Nuestras marcas</p>
      <h2 class="display mt-2 text-3xl text-tinta md:text-4xl">Marcas con las que trabajamos.</h2>
      <p class="mt-3 text-[15px] leading-relaxed text-tinta/70">
        En tienda encontrarás marcas con las que trabajamos a diario para interior,
        exterior, decoración y profesional.
      </p>
    </div>

    <ul class="mt-10 grid grid-cols-2 gap-3.5 sm:grid-cols-3 md:mt-12 md:gap-4">
      {
        marcas.map((m) => (
          <li class="marca-tile reveal">
            {m.logo ? (
              <img src={asset(m.logo)} alt={`Logotipo de ${m.nombre}`} class="marca-logo" loading="lazy" />
            ) : (
              <span class="marca-wordmark">{m.nombre}</span>
            )}
          </li>
        ))
      }
    </ul>

    <p class="reveal mt-6 text-[12.5px] text-tinta/55">
      ¿Buscas otra marca o un producto concreto? Pregúntanos: si no lo tenemos, te lo conseguimos.
    </p>
  </div>
</section>
