---
// Muro de marcas: logos SOBRE el fondo oscuro de la web (sin paneles), en
// monocromo blanco atenuado que se ilumina al pasar. Sin enlaces externos ni
// descripciones. Data-driven (site.ts). Wordmark del nombre si aún no hay logo.
import { marcas } from '../data/site';
import { asset } from '../lib/asset';
---

<section id="marcas" class="costura sec-alt py-20 text-papel md:py-28">
  <div class="container-x">
    <div class="reveal max-w-2xl">
      <p class="kicker-brocha kicker-brocha--sm text-rojo">Nuestras marcas</p>
      <h2 class="display mt-2 text-3xl text-white md:text-4xl">Marcas con las que trabajamos.</h2>
      <p class="mt-3 text-[15px] leading-relaxed text-papel/70">
        En tienda encontrarás marcas con las que trabajamos a diario para interior,
        exterior, decoración y profesional.
      </p>
    </div>

    <ul class="mt-12 grid grid-cols-2 items-center gap-x-6 gap-y-9 sm:grid-cols-3 md:mt-14 md:gap-x-10 lg:grid-cols-4">
      {
        marcas.map((m) => (
          <li class="marca-cell reveal">
            {m.logo ? (
              <img
                src={asset(m.logo)}
                alt={`Logotipo de ${m.nombre}`}
                class={`marca-logo ${m.big ? 'marca-logo--big' : ''}`}
                loading="lazy"
              />
            ) : (
              <span class="marca-wordmark">{m.nombre}</span>
            )}
          </li>
        ))
      }
    </ul>

    <p class="reveal mt-10 text-[13px] text-papel/60">
      ¿Buscas otra marca o un producto concreto? Pregúntanos: si no lo tenemos, te lo conseguimos.
    </p>
  </div>
</section>
