---
import { marcas } from '../data/site';
import { asset } from '../lib/asset';
---

<section id="marcas" class="costura py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="reveal max-w-xl">
      <p class="kicker-brocha text-rojo">Marcas</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Fabricantes que rinden en la obra.
      </h2>
    </div>

    <!-- Banda partida: cada logo sobre el fondo que le corresponde por marca -->
    <div class="reveal mt-10 grid overflow-hidden rounded-panel ring-1 ring-white/10 md:grid-cols-2">
      <a
        href={marcas[0].web}
        target="_blank"
        rel="noopener"
        class="group flex flex-col items-center justify-center gap-5 bg-papel px-8 py-14 transition-colors hover:bg-white"
      >
        <img
          src={asset(marcas[0].logo)}
          alt={`Logotipo de ${marcas[0].nombre}`}
          class="h-14 w-auto transition-transform group-hover:-translate-y-0.5"
          width="237"
          height="60"
          loading="lazy"
        />
        <p class="max-w-xs text-center text-[13px] leading-relaxed text-tinta-600">
          {marcas[0].claim}
        </p>
      </a>
      <a
        href={marcas[1].web}
        target="_blank"
        rel="noopener"
        class="group flex flex-col items-center justify-center gap-5 border-t border-white/12 bg-[linear-gradient(155deg,#2c2020,#1b1414)] px-8 py-14 transition-colors hover:bg-tinta-600 md:border-t-0 md:border-l md:border-white/15"
      >
        <img
          src={asset(marcas[1].logo)}
          alt={`Logotipo de ${marcas[1].nombre}`}
          class="h-8 w-auto transition-transform group-hover:-translate-y-0.5"
          width="520"
          height="65"
          loading="lazy"
        />
        <p class="max-w-xs text-center text-[13px] leading-relaxed text-papel/70">
          {marcas[1].claim}
        </p>
      </a>
    </div>

    <p class="reveal mt-5 text-[13px] text-papel/75">
      ¿Buscas otra marca o un producto concreto? Pregúntanos: si no lo tenemos, te lo conseguimos.
    </p>
  </div>
</section>
