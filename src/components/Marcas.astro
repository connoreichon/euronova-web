---
import { marcas } from '../data/site';
import { asset } from '../lib/asset';
import Mancha from './Mancha.astro';
---

<section id="marcas" class="relative overflow-hidden bg-negro py-16 text-papel md:py-24">
  <Mancha color="rojo" forma={7} class="-top-10 -right-14 w-52 opacity-85 md:w-64" rotar={-8} />
  <div class="container-x">
    <div class="reveal max-w-xl">
      <p class="kicker-brocha text-rojo">Marcas</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Fabricantes que rinden en la obra.
      </h2>
    </div>

    <!-- Banda partida: cada logo sobre el fondo que le corresponde por marca -->
    <div class="reveal mt-10 grid overflow-hidden rounded-3xl md:grid-cols-2">
      <a
        href={marcas[0].web}
        target="_blank"
        rel="noopener"
        class="group flex flex-col items-center justify-center gap-5 bg-papel px-8 py-14 transition-colors hover:bg-white"
      >
        <img
          src={asset(marcas[0].logo)}
          alt={`Logotipo de ${marcas[0].nombre}`}
          class="h-14 w-auto transition-transform group-hover:scale-105"
          width="237"
          height="60"
          loading="lazy"
        />
        <p class="max-w-xs text-center text-[13px] leading-relaxed text-tinta-600">
          {marcas[0].claim}
        </p>
      </a>
      <a
        href={marcas[1].web}
        target="_blank"
        rel="noopener"
        class="group flex flex-col items-center justify-center gap-5 bg-negro-600 px-8 py-14 transition-colors hover:bg-tinta-600 md:border-l md:border-white/10"
      >
        <img
          src={asset(marcas[1].logo)}
          alt={`Logotipo de ${marcas[1].nombre}`}
          class="h-8 w-auto transition-transform group-hover:scale-105"
          width="520"
          height="65"
          loading="lazy"
        />
        <p class="max-w-xs text-center text-[13px] leading-relaxed text-papel/70">
          {marcas[1].claim}
        </p>
      </a>
    </div>

    <p class="reveal mt-5 text-[13px] text-papel/50">
      ¿Buscas otra marca o un producto concreto? Pregúntanos: si no lo tenemos, te lo conseguimos.
    </p>
  </div>
</section>
