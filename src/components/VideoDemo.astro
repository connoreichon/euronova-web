---
// Sección de PROCESO ("Así acertamos el color"): sustituye al vídeo provisional
// por contenido útil y vendible. No fabrica nada: es el método que la web ya
// comunica (muestra real → carta física → tintometría → asesoramiento).
// Cuando el cliente tenga vídeo real de la tienda, puede convivir o volver aquí.
import { asset } from '../lib/asset';

const pasos = [
  {
    n: '01',
    t: 'Traes una muestra real',
    d: 'Un trozo de pared, una tela o una foto del sitio con su luz. El punto de partida para no fallar.'
  },
  {
    n: '02',
    t: 'Comparamos con la carta física',
    d: 'RAL y NCS en mano, bajo la luz real de la tienda. El color en pantalla solo orienta.'
  },
  {
    n: '03',
    t: 'Mezclamos con tintometría',
    d: 'Igualamos el tono exacto al momento, con precisión de máquina.'
  },
  {
    n: '04',
    t: 'Elegimos producto y acabado',
    d: 'Según soporte, uso y desgaste: mate, satinado o brillo. Te lo recomendamos nosotros.'
  }
];
---

<section id="proceso" class="paint-surface sec-alt py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="reveal max-w-2xl">
      <p class="kicker-brocha text-rojo">El método</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">Así acertamos el color.</h2>
      <p class="mt-4 max-w-lg text-[15px] leading-relaxed text-papel/70">
        No es a ojo. Es un método de mostrador, afinado durante años, para que el
        color de tu pared sea exactamente el que imaginas.
      </p>
    </div>

    <ol class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 md:gap-5">
      {
        pasos.map((p) => (
          <li class="proceso-paso reveal nota-mostrador flex flex-col p-5">
            <span class="proceso-num" aria-hidden="true">{p.n}</span>
            <h3 class="mt-3.5 text-[15px] font-extrabold text-tinta">{p.t}</h3>
            <p class="mt-1.5 text-[13px] leading-relaxed text-tinta/75">{p.d}</p>
          </li>
        ))
      }
    </ol>

    <div class="reveal mt-10 flex flex-wrap items-center gap-3">
      <a
        href={asset('/cartas/')}
        class="btn-pintura rounded-full bg-rojo px-6 py-3.5 text-[14px] font-bold text-white transition-transform hover:-translate-y-0.5"
      >
        Ver las cartas de color
      </a>
      <a
        href="#color"
        class="inline-flex items-center gap-2 rounded-full border border-white/25 px-6 py-3.5 text-[14px] font-semibold text-white transition-colors hover:border-white/60"
      >
        Pruébalo en la pared
      </a>
    </div>
  </div>
</section>
