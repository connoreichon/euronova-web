---
// Sección de vídeo demostrativo. Vídeo PROVISIONAL (pigmento en agua, Pixabay)
// hasta que el cliente pase el suyo. Cambia el `src`/`poster` por el vídeo real
// de la tienda cuando lo tengáis (ver ASSETS_NEEDED.md).
import { asset } from '../lib/asset';
---

<section id="video" class="py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="reveal max-w-xl">
      <p class="kicker-brocha text-rojo">En vídeo</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">Euronova, en movimiento.</h2>
      <p class="mt-4 max-w-lg text-[15px] leading-relaxed text-papel/70">
        Un vistazo a cómo trabajamos el color en tienda. Muy pronto, con nuestro propio vídeo.
      </p>
    </div>

    <div class="reveal-img relative mt-10 overflow-hidden rounded-2xl shadow-xl shadow-black/60">
      <video
        class="video-hero__media aspect-video w-full object-cover"
        poster={asset('/assets/video/pigmento-poster.jpg')}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label="Vídeo: pigmento de color mezclándose (muestra provisional)"
      >
        <source src={asset('/assets/video/pigmento.mp4')} type="video/mp4" />
      </video>
      <!-- Velo inferior + etiqueta de muestra -->
      <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-4">
        <span class="rounded-full bg-black/50 px-3 py-1 text-[11px] font-semibold tracking-wide text-white/80 backdrop-blur-sm">
          Vídeo de muestra
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  // Un pelín más lento, sin sobresaltos.
  const v = document.querySelector('#video video') as HTMLVideoElement | null;
  if (v) v.playbackRate = 0.85;
</script>
