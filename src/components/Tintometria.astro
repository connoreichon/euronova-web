---
import { site } from '../data/site';
import { RAL, NCS, BLANCOS_ROTOS } from '../data/cartas';
import Mancha from './Mancha.astro';
import BadgeCarta from './BadgeCarta.astro';
import { asset } from '../lib/asset';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
  'Hola, Pinturas Euronova. Quería pedir un color a medida: '
)}`;

// Todos los colores buscables en el tintómetro (RAL completa + selección NCS)
const TODOS = [
  ...RAL.map((x) => ({ ...x, carta: 'RAL' })),
  ...NCS.map((x) => ({ ...x, carta: 'NCS' }))
];

// Accesos rápidos bajo el panel
const RAPIDOS = ['RAL 7016', 'RAL 9010', 'RAL 3020', 'RAL 5010', 'NCS S 0502-Y', 'RAL 1015', 'RAL 6021', 'NCS S 1505-Y'];
const chips = RAPIDOS.map((c) => TODOS.find((x) => x.c === c)).filter(Boolean);
---

<section id="color" class="relative overflow-hidden bg-negro py-16 text-papel md:py-24">
  <Mancha color="rojo" forma={7} class="-bottom-12 -right-16 w-72 opacity-30 md:w-96" rotar={5} />
  <Mancha color="rojo" forma={6} class="top-8 -left-12 w-44 opacity-25" rotar={-8} />
  <div class="container-x grid items-center gap-10 md:grid-cols-2">
    <div class="reveal">
      <p class="kicker-brocha text-rojo">Tu color exacto</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Cualquier color.<br />Mezclado en minutos.
      </h2>
      <p class="mt-4 max-w-md text-[15px] leading-relaxed text-papel/75">
        Trae una muestra, una foto de tu pared o solo una idea. Con la máquina
        tintométrica y las bases de nuestras marcas sacamos el tono exacto,
        también en cantidades grandes para obra.
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a
          href={asset('/cartas/')}
          class="inline-flex items-center gap-2 rounded-full bg-rojo px-6 py-3.5 text-[14px] font-bold text-white transition-transform hover:scale-[1.04]"
        >
          Explora las cartas de colores
          <svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-wasap px-6 py-3.5 text-[14px] font-bold text-white transition-transform hover:scale-[1.04]"
        >
          Pide tu color por WhatsApp
        </a>
      </div>
    </div>

    <!-- Tintómetro: busca un código y la pared se pinta de ese color -->
    <div class="reveal">
      <label for="tinto-buscar" class="sr-only">Busca un color por código</label>
      <div class="flex items-center gap-2.5 rounded-full bg-white px-5 py-3 shadow-[4px_4px_0_0_#d2262b] transition-shadow focus-within:shadow-[6px_6px_0_0_#d2262b]">
        <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 shrink-0 text-negro/50" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.8-3.8" stroke-linecap="round" />
        </svg>
        <input
          id="tinto-buscar"
          type="search"
          placeholder="Escribe un código: 7016, 9010, S 0502-Y…"
          autocomplete="off"
          class="w-full bg-transparent text-[14px] font-semibold text-negro placeholder:font-normal placeholder:text-negro/40 focus:outline-none"
        />
      </div>
      <p id="tinto-info" class="mt-2 h-4 pl-2 text-[12px] text-papel/50" aria-live="polite"></p>

      <div
        id="pared-demo"
        class="mt-4 flex min-h-64 flex-col justify-end rounded-3xl border-2 border-white/10 p-6 shadow-[8px_8px_0_0_rgba(210,38,43,0.55)] transition-colors duration-500 md:min-h-72"
        style="background-color:#293133;"
      >
        <p id="pared-codigo" class="font-display text-3xl font-extrabold tracking-tight text-white md:text-4xl">
          RAL 7016
        </p>
        <div class="mt-1 flex items-center gap-2.5">
          <span id="pared-nombre" class="text-[14px] font-semibold text-white/85">Gris antracita</span>
          <span id="pared-carta-ral" class=""><BadgeCarta carta="RAL" /></span>
          <span id="pared-carta-ncs" class="hidden"><BadgeCarta carta="NCS" /></span>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap gap-2.5" role="group" aria-label="Colores rápidos de carta">
        {
          chips.map((c) => (
            <button
              type="button"
              class="color-chip h-9 w-9 cursor-pointer rounded-full border-2 border-white/25 transition-transform hover:scale-115 focus-visible:outline-2 focus-visible:outline-rojo"
              style={`background-color:${c!.h};`}
              data-hex={c!.h}
              data-nombre={c!.n}
              data-codigo={c!.c}
              data-carta={c!.carta}
              title={`${c!.n} · ${c!.c}`}
              aria-label={`Ver ${c!.n} (${c!.c})`}
            />
          ))
        }
      </div>
      <p class="mt-3 text-[12px] text-papel/50">
        Color orientativo en pantalla — la referencia válida es la carta física en tienda.
      </p>
    </div>
  </div>

  <!-- Blancos rotos que se llevan -->
  <div class="container-x mt-16 md:mt-20">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="kicker-brocha text-rojo" style="font-size:1.8rem;">Tendencia</p>
        <h3 class="display mt-1 text-2xl text-white md:text-3xl">Blancos rotos que se llevan.</h3>
      </div>
      <p class="max-w-sm text-[13px] leading-relaxed text-papel/60">
        Los blancos con matiz son lo más pedido del mostrador. Pídelos con su
        código, tal cual.
      </p>
    </div>
    <div class="mt-7 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        BLANCOS_ROTOS.map((b) => (
          <button
            type="button"
            class="blanco-item reveal group cursor-pointer overflow-hidden rounded-2xl border-2 border-white/10 bg-white/5 text-left transition-all hover:-translate-x-0.5 hover:-translate-y-1 hover:shadow-[6px_6px_0_0_#d2262b]"
            data-hex={b.h}
            data-nombre={b.n}
            data-codigo={b.c}
            data-carta={b.carta}
            aria-label={`Ver ${b.n} (${b.c}) en el tintómetro`}
          >
            <div class="aspect-[5/3] transition-transform group-hover:scale-[1.03]" style={`background-color:${b.h};`} />
            <div class="px-3.5 py-3">
              <div class="flex items-center justify-between gap-2">
                <p class="truncate text-[13px] font-bold text-white">{b.n}</p>
                <BadgeCarta carta={b.carta} class="scale-90" />
              </div>
              <p class="mt-0.5 text-[11.5px] font-semibold text-papel/75">{b.c}</p>
              <p class="mt-1 text-[11px] leading-relaxed text-papel/50">{b.nota}</p>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</section>

<script is:inline define:vars={{ TODOS }}>
  const buscar = document.getElementById('tinto-buscar');
  const info = document.getElementById('tinto-info');
  const pared = document.getElementById('pared-demo');
  const codigoEl = document.getElementById('pared-codigo');
  const nombreEl = document.getElementById('pared-nombre');
  const badgeRal = document.getElementById('pared-carta-ral');
  const badgeNcs = document.getElementById('pared-carta-ncs');

  const luminancia = (hex) => {
    const n = parseInt(hex.slice(1), 16);
    return (0.299 * (n >> 16) + 0.587 * ((n >> 8) & 255) + 0.114 * (n & 255)) / 255;
  };

  const pintar = (color) => {
    pared.style.backgroundColor = color.h;
    codigoEl.textContent = color.c;
    nombreEl.textContent = color.n;
    const oscuro = luminancia(color.h) > 0.6;
    codigoEl.style.color = oscuro ? '#171111' : '#ffffff';
    nombreEl.style.color = oscuro ? 'rgba(23,17,17,0.75)' : 'rgba(255,255,255,0.85)';
    badgeRal.classList.toggle('hidden', color.carta !== 'RAL');
    badgeNcs.classList.toggle('hidden', color.carta !== 'NCS');
  };

  const norm = (s) => s.toUpperCase().replace(/[\s\-]/g, '');

  buscar?.addEventListener('input', () => {
    const q = norm(buscar.value);
    if (!q) {
      info.textContent = '';
      return;
    }
    const hits = TODOS.filter((c) => norm(c.c).includes(q) || c.n.toUpperCase().includes(buscar.value.toUpperCase()));
    if (hits.length) {
      pintar(hits[0]);
      info.textContent =
        hits.length === 1 ? '¡Encontrado!' : `${hits.length} coincidencias — mostrando ${hits[0].c}`;
    } else {
      info.textContent = 'No está en la web: pregúntanos, en tienda hay miles más.';
    }
  });

  document.querySelectorAll('.color-chip, .blanco-item').forEach((el) => {
    el.addEventListener('click', () => {
      pintar({ h: el.dataset.hex, c: el.dataset.codigo, n: el.dataset.nombre, carta: el.dataset.carta });
      if (el.classList.contains('blanco-item')) {
        document.getElementById('color')?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
