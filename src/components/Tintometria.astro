---
import { site, coloresTinto } from '../data/site';
import Mancha from './Mancha.astro';
import { asset } from '../lib/asset';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
  'Hola, Pinturas Euronova. Quería pedir un color a medida.'
)}`;
---

<section id="color" class="relative overflow-hidden bg-negro-600 py-16 text-papel md:py-24">
  <Mancha color="rojo" forma={3} class="-bottom-14 -right-16 w-72 opacity-[0.15] md:w-96" rotar={12} />
  <Mancha color="blanco" forma={2} class="top-10 -left-16 w-44 opacity-[0.08]" rotar={70} />
  <div class="container-x grid items-center gap-10 md:grid-cols-2">
    <div class="reveal">
      <p class="kicker-brocha text-rojo">Tintometría en tienda</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Cualquier color.<br />Mezclado en minutos.
      </h2>
      <p class="mt-4 max-w-md text-[15px] leading-relaxed text-papel/75">
        Trae una muestra, una foto de tu pared o solo una idea. Con la máquina
        tintométrica y las bases de nuestras marcas sacamos el tono exacto,
        también en cantidades grandes para obra.
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a
          href={asset('/cartas/')}
          class="inline-flex items-center gap-2 rounded-full bg-rojo px-6 py-3.5 text-[14px] font-bold text-white transition-transform hover:scale-[1.04]"
        >
          Explora las cartas de colores
          <svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-wasap px-6 py-3.5 text-[14px] font-bold text-white transition-transform hover:scale-[1.04]"
        >
          Pide tu color por WhatsApp
        </a>
      </div>
    </div>

    <!-- Panel interactivo: toca un chip y la "pared" cambia de color -->
    <div class="reveal">
      <div
        id="pared-demo"
        class="flex min-h-56 flex-col justify-end rounded-3xl p-6 transition-colors duration-500 md:min-h-72"
        style="background-color:#383e42;"
      >
        <span
          id="pared-nombre"
          class="w-fit rounded-full bg-black/30 px-3.5 py-1.5 text-[12px] font-semibold text-white backdrop-blur-sm"
        >
          Gris antracita · RAL 7016
        </span>
      </div>
      <div class="mt-4 flex flex-wrap gap-2.5" role="group" aria-label="Prueba colores de carta RAL y NCS">
        {
          coloresTinto.map((c, i) => (
            <button
              type="button"
              class="color-chip h-9 w-9 cursor-pointer rounded-full border-2 border-white/25 transition-transform hover:scale-115 focus-visible:outline-2 focus-visible:outline-rojo"
              style={`background-color:${c.hex};`}
              data-hex={c.hex}
              data-nombre={c.nombre}
              data-codigo={c.codigo}
              title={`${c.nombre} · ${c.codigo}`}
              aria-label={`Ver pared en ${c.nombre} (${c.codigo})`}
              aria-pressed={i === 0 ? 'true' : 'false'}
            />
          ))
        }
      </div>
      <p class="mt-3 text-[12px] text-papel/50">
        Colores reales de carta RAL y NCS. En tienda, miles más: RAL, NCS,
        Eurotrend y las cartas de cada fabricante.
      </p>
    </div>
  </div>
</section>

<script>
  const pared = document.getElementById('pared-demo');
  const nombre = document.getElementById('pared-nombre');
  const chips = document.querySelectorAll<HTMLButtonElement>('.color-chip');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      if (!pared || !nombre) return;
      pared.style.backgroundColor = chip.dataset.hex ?? '#383e42';
      nombre.textContent = `${chip.dataset.nombre ?? ''} · ${chip.dataset.codigo ?? ''}`;
      chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
    });
  });
</script>
