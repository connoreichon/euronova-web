---
// Distintivo de carta: chip tipográfico sobrio (punto de color + sistema).
// Alineación robusta con leading-none para que quede idéntico en todas las
// tarjetas, sin depender de la geometría de un icono.
interface Props {
  carta: 'RAL' | 'NCS';
  class?: string;
}
const { carta, class: className = '' } = Astro.props;
const punto = carta === 'RAL' ? '#d2262b' : '#c9c4b8';
---

<span
  class={`inline-flex shrink-0 items-center gap-1.5 leading-none ${className}`}
>
  <span class="h-[7px] w-[7px] shrink-0 rounded-full" style={`background:${punto}`}></span>
  <span class="text-[10px] font-semibold tracking-[0.14em] whitespace-nowrap text-papel/60 uppercase">
    {carta}
  </span>
</span>
