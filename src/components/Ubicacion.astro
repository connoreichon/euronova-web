---
import { site } from '../data/site';
---

<section id="tienda" class="bg-negro py-20 text-papel md:py-32">
  <div class="container-x grid gap-12 md:grid-cols-2">
    <div class="reveal">
      <p class="kicker-brocha text-rojo">Ven a vernos</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        La tienda, en Las Lagunas.
      </h2>

      <address class="mt-6 space-y-4 text-[15px] not-italic">
        <p class="flex items-start gap-3">
          <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 shrink-0 text-rojo" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" stroke-linejoin="round"/>
            <circle cx="12" cy="10" r="2.6"/>
          </svg>
          <span>
            {site.direccion}<br />
            <span class="text-papel/65">{site.ciudad}</span>
          </span>
        </p>
        <p class="flex items-center gap-3">
          <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 text-rojo" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M5 4h4l1.5 4.5L8 10a12 12 0 0 0 6 6l1.5-2.5L20 15v4a1.5 1.5 0 0 1-1.7 1.5A16.5 16.5 0 0 1 3.5 5.7 1.5 1.5 0 0 1 5 4Z" stroke-linejoin="round"/>
          </svg>
          <a href={`tel:${site.telefonoLink}`} class="inline-block py-2 -my-2 font-semibold text-white underline-offset-4 hover:underline">
            {site.telefono}
          </a>
        </p>
        <p class="flex items-center gap-3">
          <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 text-rojo" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3.5" y="5.5" width="17" height="13" rx="2"/>
            <path d="m4.5 7 7.5 6 7.5-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <a href={`mailto:${site.email}`} class="inline-block py-2 -my-2 text-papel/85 underline-offset-4 hover:underline">
            {site.email}
          </a>
        </p>
      </address>

      <h3 class="kicker mt-9 text-rojo">Horario</h3>
      <ul class="mt-3 max-w-sm space-y-2">
        {
          site.horario.map((h) => (
            <li class="flex items-baseline justify-between gap-4 border-b border-white/12 pb-2 text-[14px]">
              <span class="font-medium text-white">{h.dia}</span>
              <span class={h.cerrado ? 'text-papel/55' : 'text-papel/80'}>{h.horas}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-3 text-[13px] text-papel/60">{site.avisoHorario}</p>
    </div>

    <div class="reveal flex flex-col">
      {
        site.mapsEmbed ? (
          <iframe
            src={site.mapsEmbed}
            title={`Mapa: ${site.nombre}`}
            class="min-h-80 w-full flex-1 rounded-2xl border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        ) : (
          <div class="mat-suelo relative flex min-h-80 flex-1 flex-col items-center justify-center gap-4 rounded-2xl p-8 text-center">
            <svg viewBox="0 0 24 24" class="h-12 w-12 text-rojo" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" stroke-linejoin="round" />
              <circle cx="12" cy="10" r="2.6" />
            </svg>
            <p class="max-w-xs text-[14px] font-medium text-tinta">
              El mapa se activará al confirmar la dirección exacta del local.
            </p>
            <a
              href={site.mapsLink}
              target="_blank"
              rel="noopener"
              class="rounded-full bg-negro px-5 py-2.5 text-[13px] font-bold text-white transition-transform hover:-translate-y-0.5"
            >
              Buscar en Google Maps
            </a>
          </div>
        )
      }
      <a
        href={`tel:${site.telefonoLink}`}
        class="mt-5 inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3.5 text-[14px] font-bold text-rojo transition-transform hover:-translate-y-0.5"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M5 4h4l1.5 4.5L8 10a12 12 0 0 0 6 6l1.5-2.5L20 15v4a1.5 1.5 0 0 1-1.7 1.5A16.5 16.5 0 0 1 3.5 5.7 1.5 1.5 0 0 1 5 4Z" stroke-linejoin="round" />
        </svg>
        Llámanos: {site.telefono}
      </a>
    </div>
  </div>
</section>
