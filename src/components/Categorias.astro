---
// Escaparate editorial (MASTER): composición bento intencional — una pieza
// protagonista, dos medianas y tres de apoyo. Tiles editoriales sin CTA
// repetido: la fotografía manda. El asesoramiento se resuelve en una línea
// bajo la rejilla, no seis veces.
import { categorias, complementosNota } from '../data/site';
import { asset } from '../lib/asset';

// Ritmo del bento: [protagonista 3x2, mediana 3, mediana 3, apoyo 2, 2, 2]
const SPAN = [
  'sm:col-span-2 lg:col-span-3 lg:row-span-2',
  'lg:col-span-3',
  'lg:col-span-3',
  'lg:col-span-2',
  'lg:col-span-2',
  'lg:col-span-2'
];
const MEDIA = [
  'aspect-[4/3] lg:aspect-auto lg:h-full',
  'aspect-[16/9]',
  'aspect-[16/9]',
  'aspect-[16/10]',
  'aspect-[16/10]',
  'aspect-[16/10]'
];
---

<section id="productos" class="py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="reveal halo-rojo halo-rojo--tenue max-w-xl">
      <p class="kicker-brocha text-rojo">Escaparate</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Elige qué vas<br />a pintar.
      </h2>
      <p class="mt-4 text-[15px] leading-relaxed text-papel/70">
        Interior y exterior, esmaltes, madera, impermeabilizantes y ecológicas.
        Pincha una categoría y verás nuestra gama; el color te lo mezclamos a medida en tienda.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-6">
      {
        categorias.map((c, i) => (
          <a
            href={asset('/productos/' + c.slug + '/')}
            class={`pieza reveal group block ${SPAN[i]} ${i === 0 ? 'pieza--sobre relative' : ''}`}
            aria-label={`Ver productos de ${c.nombre}`}
          >
            <div class={`pieza__media ${MEDIA[i]} ${i === 0 ? 'lg:min-h-full' : ''}`}>
              <img
                src={asset(c.img)}
                alt={c.alt}
                style={`object-position:${c.pos ?? '50% 50%'};`}
                width="1280"
                height="853"
                loading="lazy"
              />
            </div>
            {i === 0 ? (
              <div class="pieza__texto">
                <p class="text-[11px] font-semibold tracking-[0.16em] text-white/60 uppercase">{c.acabado}</p>
                <h3 class="font-display mt-1 text-2xl font-bold text-white">{c.nombre}</h3>
                <p class="mt-1.5 max-w-sm text-[13.5px] leading-relaxed text-white/75">{c.desc}</p>
                <span class="pieza__cta mt-3 inline-flex items-center gap-1.5 text-[13px] font-bold text-white">
                  Ver la gama
                  <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </span>
              </div>
            ) : (
              <div class="mt-4">
                <p class="text-[11px] font-semibold tracking-[0.16em] text-papel/55 uppercase">{c.acabado}</p>
                <h3 class="font-display mt-1 flex items-center gap-1.5 text-lg font-bold text-white">
                  {c.nombre}
                  <svg viewBox="0 0 16 16" class="pieza__arrow h-3.5 w-3.5 text-rojo" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </h3>
                <p class="mt-1 text-[13.5px] leading-relaxed text-papel/60">{c.desc}</p>
              </div>
            )}
          </a>
        ))
      }
    </div>

    <div class="reveal mt-12 flex flex-col gap-4 border-t border-white/10 pt-8 md:flex-row md:items-center md:justify-between">
      <p class="max-w-xl text-[14px] leading-relaxed text-papel/70">
        ¿Dudas con un producto? Te asesoramos en tienda según el soporte, el uso
        y el acabado que buscas. {complementosNota}
      </p>
      <a
        href="#tienda"
        class="inline-flex shrink-0 items-center gap-1.5 py-2 -my-2 text-[13px] font-semibold text-white transition-colors hover:text-rojo"
      >
        Ven a vernos
        <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
