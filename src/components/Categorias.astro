---
// Escaparate editorial (Fase 3 del MASTER DESIGN SYSTEM): composición bento
// intencional — una pieza protagonista, dos medianas y tres de apoyo.
// Sin cajas clonadas, sin adornos: foto protagonista + texto + CTA discreto.
import { site, categorias, complementosNota } from '../data/site';
import { asset } from '../lib/asset';

const waCat = (cat: string) =>
  `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
    `Hola, Pinturas Euronova. Quería consultar por ${cat.toLowerCase()}.`
  )}`;

// Ritmo del bento: [protagonista 3x2, mediana 3, mediana 3, apoyo 2, 2, 2]
const SPAN = [
  'sm:col-span-2 lg:col-span-3 lg:row-span-2',
  'lg:col-span-3',
  'lg:col-span-3',
  'lg:col-span-2',
  'lg:col-span-2',
  'lg:col-span-2'
];
const MEDIA = [
  'aspect-[4/3] lg:aspect-auto lg:h-full',
  'aspect-[16/9]',
  'aspect-[16/9]',
  'aspect-[16/10]',
  'aspect-[16/10]',
  'aspect-[16/10]'
];
---

<section id="productos" class="bg-negro py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="reveal max-w-xl">
      <p class="kicker-brocha text-rojo">Escaparate</p>
      <h2 class="display mt-2 text-3xl text-white md:text-5xl">
        Todo en pintura,<br />del bote a tu pared.
      </h2>
      <p class="mt-4 text-[15px] leading-relaxed text-papel/70">
        Sin tienda online y sin líos: mira lo que trabajamos, pregunta por
        WhatsApp y te lo dejamos preparado en el mostrador.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-6">
      {
        categorias.map((c, i) => (
          <a
            href={waCat(c.nombre)}
            target="_blank"
            rel="noopener"
            aria-label={`${c.nombre}: consultar por WhatsApp`}
            class={`pieza reveal group ${SPAN[i]} ${i === 0 ? 'pieza--sobre relative' : ''}`}
          >
            <div class={`pieza__media ${MEDIA[i]} ${i === 0 ? 'lg:min-h-full' : ''}`}>
              <img
                src={asset(c.img)}
                alt={c.alt}
                style={`object-position:${c.pos ?? '50% 50%'};`}
                width="1280"
                height="853"
                loading="lazy"
              />
            </div>
            {i === 0 ? (
              <div class="pieza__texto">
                <p class="text-[11px] font-semibold tracking-[0.16em] text-white/60 uppercase">{c.acabado}</p>
                <h3 class="font-display mt-1 text-2xl font-bold text-white">{c.nombre}</h3>
                <p class="mt-1.5 max-w-sm text-[13.5px] leading-relaxed text-white/75">{c.desc}</p>
                <p class="mt-3 text-[12.5px] font-semibold text-white/80 transition-colors group-hover:text-white">
                  Consultar por WhatsApp →
                </p>
              </div>
            ) : (
              <div class="mt-4">
                <p class="text-[11px] font-semibold tracking-[0.16em] text-papel/45 uppercase">{c.acabado}</p>
                <h3 class="font-display mt-1 text-lg font-bold text-white">{c.nombre}</h3>
                <p class="mt-1 text-[13.5px] leading-relaxed text-papel/60">{c.desc}</p>
                <p class="mt-2 text-[12.5px] font-semibold text-papel/50 transition-colors group-hover:text-white">
                  Consultar por WhatsApp →
                </p>
              </div>
            )}
          </a>
        ))
      }
    </div>

    <p class="reveal mt-10 text-[13px] text-papel/50">{complementosNota}</p>
  </div>
</section>
