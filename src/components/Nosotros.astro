---
// Bloque de confianza (Fase 4 del MASTER): editorial, sin tarjetas.
// Datos de confianza como tipografía con filetes, no como "stats de SaaS".
import { site } from '../data/site';
import { asset } from '../lib/asset';

const confianza = [
  {
    dato: '+20 años',
    texto: 'mezclando color y asesorando a clientes de la zona.'
  },
  {
    dato: 'Color a medida',
    texto: 'trae una muestra o dinos el tono que buscas.'
  },
  {
    dato: 'WhatsApp directo',
    texto: 'pregunta stock, precio o qué producto usar.'
  }
];
---

<section id="nosotros" class="bg-negro py-20 text-papel md:py-32">
  <div class="container-x">
    <div class="grid items-start gap-12 md:grid-cols-[1.2fr_1fr]">
      <div class="reveal">
        <p class="kicker-brocha text-rojo">La tienda</p>
        <h2 class="display mt-2 max-w-lg text-3xl text-white md:text-5xl">
          Más de 20 años ayudando a elegir pintura.
        </h2>
        <p class="mt-6 max-w-lg text-[15px] leading-relaxed text-papel/70">
          En Euronova no solo vendemos botes. Te preguntamos qué vas a pintar,
          dónde está la superficie y qué acabado buscas para recomendarte una
          solución realista — a particulares y a pintores profesionales de la
          zona: {site.zona}.
        </p>
      </div>

      <!-- Foto provisional (estantería de botes de pintura mezclada, licencia
           Pixabay). TODO: sustituir por una foto REAL de la tienda de Euronova
           — mostrador, estanterías o la tintométrica. Ver ASSETS_NEEDED.md. -->
      <div class="reveal">
        <div class="overflow-hidden rounded-2xl">
          <img
            src={asset('/assets/img/tienda/botes.jpg')}
            alt="Estantería con botes de pintura de distintos colores mezclados"
            class="aspect-[4/3] w-full object-cover"
            width="1137"
            height="853"
            loading="lazy"
          />
        </div>
        <p class="mt-2 text-[11px] text-papel/40">Foto de muestra · pendiente de la foto real de la tienda</p>
      </div>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-3 md:mt-20">
      {
        confianza.map((c) => (
          <div class="reveal border-t border-white/15 pt-5">
            <p class="font-display text-xl font-bold text-white">{c.dato}</p>
            <p class="mt-1.5 max-w-[26ch] text-[13.5px] leading-relaxed text-papel/60">{c.texto}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
