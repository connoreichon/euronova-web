---
// Logotipo calcado del rótulo real de la tienda, con su fuente ORIGINAL:
// Handel Gothic BT autohospedada (la E tipo € es la propia del tipo de letra).
//  - "Euronov@" negro con borde blanco, inclinado como en el cartel.
//  - "pinturas" cursiva negra con borde blanco sobre la pincelada azul.
//  - Eslogan: "La vida es del color que tú quieras pintarla".
// `variant="compact"`: solo el wordmark (para el header).
interface Props {
  variant?: 'full' | 'compact';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;
---

{
  variant === 'compact' ? (
    <svg viewBox="0 0 600 112" class={className} role="img" aria-label="Pinturas Euronova">
      <text
        x="10"
        y="88"
        font-family="'HandelGothic', 'Archivo', sans-serif"
        font-size="82"
        fill="#0d0d0d"
        stroke="#fff"
        stroke-width="6"
        paint-order="stroke"
        transform="skewX(-8)"
        textLength="545"
        lengthAdjust="spacingAndGlyphs"
      >
        Euronov@
      </text>
    </svg>
  ) : (
    <svg
      viewBox="0 0 780 258"
      class={className}
      role="img"
      aria-label="Pinturas Euronova — La vida es del color que tú quieras pintarla"
    >
      <g transform="translate(408 4)">
        <path
          d="M10 34 C 50 20 110 18 160 22 C 220 16 270 20 306 26 C 322 28 338 24 350 32 C 338 36 346 44 332 42 C 342 52 318 48 324 56 C 306 62 296 52 278 58 C 220 66 150 64 96 60 C 62 64 28 60 12 50 C 4 44 2 40 10 34 Z"
          fill="#1a4fa8"
        />
        <path
          d="M296 26 C 320 22 340 26 350 32 C 338 36 346 44 332 42 C 342 52 318 48 324 56 C 312 60 300 54 288 56 C 302 48 290 34 296 26 Z"
          fill="#2f74d0"
          opacity="0.9"
        />
        <text
          x="34"
          y="52"
          font-family="'Archivo Black', 'Archivo', sans-serif"
          font-size="44"
          fill="#0d0d0d"
          stroke="#fff"
          stroke-width="5"
          paint-order="stroke"
          transform="skewX(-12)"
        >
          pinturas
        </text>
      </g>

      <text
        x="10"
        y="164"
        font-family="'HandelGothic', 'Archivo', sans-serif"
        font-size="124"
        fill="#0d0d0d"
        stroke="#fff"
        stroke-width="9"
        paint-order="stroke"
        transform="skewX(-8)"
        textLength="722"
        lengthAdjust="spacingAndGlyphs"
      >
        Euronov@
      </text>

      <text
        x="404"
        y="234"
        text-anchor="middle"
        font-family="'Archivo Black', 'Archivo', sans-serif"
        font-size="33"
        fill="#0d0d0d"
        stroke="#fff"
        stroke-width="4.5"
        paint-order="stroke"
        transform="skewX(-8)"
        textLength="716"
        lengthAdjust="spacingAndGlyphs"
      >
        La vida es del color que tú quieras pintarla
      </text>
    </svg>
  )
}
