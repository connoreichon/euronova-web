---
// Logotipo REAL de la tienda: imagen del rótulo facilitada por el usuario
// (recorte del cartel con el fondo rojo eliminado por croma). Es el logo
// exacto: tipografía, pincelada azul de "pinturas" y proporciones originales.
//  - `full`: rótulo + eslogan debajo ("La vida es del color que tú quieras pintarla").
//  - `compact`: versión pequeña para el header.
import { asset } from '../lib/asset';

interface Props {
  variant?: 'full' | 'compact';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;
---

{
  variant === 'compact' ? (
    <img
      src={asset('/assets/marca/logo-euronova-header.png')}
      alt="Pinturas Euronova"
      class={className}
      width="520"
      height="96"
      loading="eager"
    />
  ) : (
    <div class={className}>
      <img
        src={asset('/assets/marca/logo-euronova.png')}
        alt="Pinturas Euronova"
        class="w-full"
        width="1600"
        height="294"
        loading="eager"
        fetchpriority="high"
      />
      <svg viewBox="0 0 780 56" class="mt-1 w-full" role="img" aria-label="La vida es del color que tú quieras pintarla">
        <text
          x="404"
          y="40"
          text-anchor="middle"
          font-family="'Archivo Black', 'Archivo', sans-serif"
          font-size="34"
          fill="#0d0d0d"
          stroke="#fff"
          stroke-width="4.5"
          paint-order="stroke"
          transform="skewX(-8)"
          textLength="716"
          lengthAdjust="spacingAndGlyphs"
        >
          La vida es del color que tú quieras pintarla
        </text>
      </svg>
    </div>
  )
}
