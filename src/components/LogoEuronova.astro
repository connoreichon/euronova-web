---
// Logotipo DEFINITIVO: arte del rotulista (versión sobre blanco → transparente,
// contorno blanco fino horneado) con la E REAL del cartel fotografiada por el
// cliente, enderezada e integrada con el mismo negro y contorno (sin costura).
import { asset } from '../lib/asset';

interface Props {
  variant?: 'full' | 'compact';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;
---

{
  variant === 'compact' ? (
    <img
      src={asset('/assets/marca/word.png')}
      alt="Pinturas Euronova"
      class={className}
      width="605"
      height="89"
      loading="eager"
    />
  ) : (
    <img
      src={asset('/assets/marca/lockup.png')}
      alt="Pinturas Euronova — La vida es del color que tú quieras pintarla"
      class={className}
      width="868"
      height="239"
      loading="eager"
      fetchpriority="high"
    />
  )
}
