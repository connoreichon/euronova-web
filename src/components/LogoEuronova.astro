---
// Logotipo calcado del rótulo real de la tienda:
//  - "E" dibujada a mano según el cartel: C ancha con corte diagonal en la
//    esquina superior izquierda y barra central CORTA (no llega a las puntas).
//  - "uronov@" en Handel Gothic BT autohospedada (la fuente real del rótulo).
//  - "pinturas" cursiva negra sobre pincelada azul con cerdas y llamas.
//  - Eslogan: "La vida es del color que tú quieras pintarla".
// `variant="compact"`: solo el wordmark (para el header).
interface Props {
  variant?: 'full' | 'compact';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;

// La E del cartel (caja local 0..96 x, 0..104 y):
// contorno exterior con chaflán arriba-izquierda, terminales radiales a la
// derecha, hueco interior y barra central corta fusionada al trazo izquierdo.
const E_PATH =
  'M92 24 A48 48 0 0 0 40 2 L16 20 A48 48 0 0 0 2 54 A48 48 0 0 0 44 102 ' +
  'A48 48 0 0 0 92 80 L76 66 A28 28 0 0 1 50 82 A28 28 0 0 1 22 52 ' +
  'A28 28 0 0 1 50 22 A28 28 0 0 1 76 38 Z';
const E_BAR =
  'M24 42 H70 Q75 42 75 47 V57 Q75 62 70 62 H24 Q20 62 20 57 V47 Q20 42 24 42 Z';
---

{
  variant === 'compact' ? (
    <svg viewBox="0 0 600 112" class={className} role="img" aria-label="Pinturas Euronova">
      <g transform="skewX(-8)" stroke="#fff" stroke-linejoin="round" paint-order="stroke" fill="#0d0d0d">
        <g transform="translate(16 16) scale(0.7)">
          <path d={E_PATH} stroke-width="10" />
          <path d={E_BAR} stroke-width="10" />
        </g>
        <text
          x="92"
          y="88"
          font-family="'HandelGothic', 'Archivo', sans-serif"
          font-size="80"
          stroke-width="6"
          textLength="472"
          lengthAdjust="spacingAndGlyphs"
        >
          uronov@
        </text>
      </g>
    </svg>
  ) : (
    <svg
      viewBox="0 0 780 258"
      class={className}
      role="img"
      aria-label="Pinturas Euronova — La vida es del color que tú quieras pintarla"
    >
      <g transform="translate(400 2)">
        <g fill="#1a4fa8">
          <path d="M14 40 C 40 30 90 26 150 28 C 220 24 280 28 316 30 L 344 18 C 336 28 352 26 360 22 L 348 34 C 358 34 366 30 374 26 L 356 44 C 364 46 372 44 378 42 L 352 54 C 340 60 320 58 300 60 C 230 66 150 64 90 60 C 50 62 20 56 14 48 Z" />
          <path d="M330 26 C 344 20 356 16 368 14 L 352 30 C 362 30 372 26 380 24 L 360 40 C 350 44 340 44 332 44 C 338 36 330 32 330 26 Z" fill="#2f74d0" opacity="0.9" />
        </g>
        <g stroke="#123c86" stroke-width="2.5" opacity="0.45" fill="none">
          <path d="M30 42 C 100 36 200 34 300 38" />
          <path d="M40 50 C 120 46 220 44 310 48" />
          <path d="M60 34 C 140 30 230 30 305 32" />
        </g>
        <path d="M50 30 C 130 24 240 24 316 28" stroke="#5a95e4" stroke-width="3" opacity="0.55" fill="none" />
        <text
          x="42"
          y="52"
          font-family="'Archivo Black', 'Archivo', sans-serif"
          font-size="44"
          fill="#0d0d0d"
          stroke="#fff"
          stroke-width="5"
          paint-order="stroke"
          transform="skewX(-12)"
        >
          pinturas
        </text>
      </g>

      <g transform="skewX(-8)" stroke="#fff" stroke-linejoin="round" paint-order="stroke" fill="#0d0d0d">
        <g transform="translate(24 62) scale(0.99)">
          <path d={E_PATH} stroke-width="10" />
          <path d={E_BAR} stroke-width="10" />
        </g>
        <text
          x="132"
          y="164"
          font-family="'HandelGothic', 'Archivo', sans-serif"
          font-size="118"
          stroke-width="9"
          textLength="600"
          lengthAdjust="spacingAndGlyphs"
        >
          uronov@
        </text>
      </g>

      <text
        x="404"
        y="234"
        text-anchor="middle"
        font-family="'Archivo Black', 'Archivo', sans-serif"
        font-size="33"
        fill="#0d0d0d"
        stroke="#fff"
        stroke-width="4.5"
        paint-order="stroke"
        transform="skewX(-8)"
        textLength="716"
        lengthAdjust="spacingAndGlyphs"
      >
        La vida es del color que tú quieras pintarla
      </text>
    </svg>
  )
}
