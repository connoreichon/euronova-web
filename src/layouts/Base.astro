---
import '../styles/global.css';
import { site } from '../data/site';
import { asset } from '../lib/asset';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.nombre} · Tienda de pinturas en Las Lagunas de Mijas (Málaga)`,
  description = `Tienda de pinturas en Las Lagunas de Mijas con más de 20 años: tintometría (cualquier color a medida), Bupisa, Rugoplast, esmaltes, fachadas e impermeabilización. Para particulares y pintores profesionales de la Costa del Sol.`
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={asset('/assets/favicon.png')} />
    <link rel="apple-touch-icon" href={asset('/assets/apple-touch-icon.png')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800&family=Inter:wght@400;500;600&family=Nanum+Brush+Script&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#d2262b" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL(asset('/assets/og.jpg'), Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(asset('/assets/og.jpg'), Astro.site)} />

    <!-- Datos estructurados: comercio local (SEO "tienda de pinturas Mijas") -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'HardwareStore',
        name: site.nombre,
        legalName: site.razonSocial,
        description,
        image: new URL(asset('/assets/og.jpg'), Astro.site).href,
        url: Astro.site?.href,
        telephone: site.telefonoLink,
        email: site.email,
        priceRange: '€€',
        currenciesAccepted: 'EUR',
        address: {
          '@type': 'PostalAddress',
          streetAddress: site.direccion,
          addressLocality: 'Las Lagunas de Mijas',
          postalCode: '29651',
          addressRegion: 'Málaga',
          addressCountry: 'ES'
        },
        areaServed: ['Mijas', 'Fuengirola', 'Costa del Sol'],
        sameAs: [site.redes.instagram, site.redes.facebook],
        openingHoursSpecification: {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '07:30',
          closes: '19:30'
        },
        makesOffer: [
          'Pintura para interior',
          'Pintura para fachadas',
          'Esmaltes',
          'Barnices y protección de madera',
          'Pintura para suelos',
          'Impermeabilización',
          'Color a medida (tintometría)'
        ]
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-full bg-white px-4 py-2 text-[13px] font-bold text-negro focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-100"
    >
      Saltar al contenido
    </a>
    <slot />

    <script>
      // Habilita las animaciones basadas en JS (p. ej. el recorte de los
      // rótulos "a brocha"): sin JS, el CSS no los recorta y se ven completos.
      document.documentElement.classList.add('js-anim');

      // Revela secciones + "pinta" los rótulos a brocha al entrar en viewport.
      const els = document.querySelectorAll('.reveal');
      const kickers = document.querySelectorAll('.kicker-brocha');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));

        const ioBrocha = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('pintado');
                ioBrocha.unobserve(e.target);
              }
            }
          },
          { threshold: 0.6 }
        );
        kickers.forEach((el) => ioBrocha.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
        kickers.forEach((el) => el.classList.add('pintado'));
      }
    </script>

    <script>
      // ---- Mancha de pintura al clicar ----
      // Una silueta de salpicadura REAL (PNG) aparece donde pinchas, florece y
      // se disuelve sola de forma orgánica. Respeta prefers-reduced-motion.
      const reduceMov = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const BASE_URL = import.meta.env.BASE_URL.replace(/\/$/, '');
      if (!reduceMov) {
        let manchasVivas = 0;
        // 'click' (no 'pointerdown') para no manchar al arrastrar el dedo/scroll;
        // e.detail===0 = activación por teclado → se ignora.
        addEventListener('click', (e) => {
          if (!e.detail || manchasVivas > 2) return;
          manchasVivas++;
          const img = document.createElement('img');
          img.className = 'mancha-click';
          const variante = 2 + ((Math.random() * 2) | 0); // splat2 / splat3
          img.src = `${BASE_URL}/assets/manchas/splat${variante}-rojo.png`;
          img.alt = '';
          const tam = 74 + Math.random() * 66; // 74–140 px
          img.style.left = e.clientX + 'px';
          img.style.top = e.clientY + 'px';
          img.style.width = tam.toFixed(0) + 'px';
          document.body.appendChild(img);
          const rot = (Math.random() * 360) | 0;
          const t = (s: number) => `translate(-50%,-50%) scale(${s}) rotate(${rot}deg)`;
          img.animate(
            [
              { transform: t(0.35), opacity: 0 },
              { transform: t(1.04), opacity: 0.94, offset: 0.16 },
              { transform: t(1), opacity: 0.9, offset: 0.42 },
              { transform: t(1.09), opacity: 0 }
            ],
            { duration: 920, easing: 'cubic-bezier(.2,.7,.3,1)', fill: 'forwards' }
          );
          setTimeout(() => {
            img.remove();
            manchasVivas--;
          }, 980);
        });
      }
    </script>
  </body>
</html>
