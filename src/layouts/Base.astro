---
import '../styles/global.css';
import { site } from '../data/site';
import { asset } from '../lib/asset';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.nombre} · Tienda de pinturas en Las Lagunas de Mijas (Málaga)`,
  description = `Tienda de pinturas en Las Lagunas de Mijas con más de 20 años: tintometría (cualquier color a medida), Bupisa, Rugoplast, esmaltes, fachadas e impermeabilización. Para particulares y pintores profesionales de la Costa del Sol.`
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={asset('/assets/logo.svg')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Archivo+Black&family=Inter:wght@400;500;600&family=Nanum+Brush+Script&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#d2262b" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary" />

    <!-- Datos estructurados: comercio local (SEO "tienda de pinturas Mijas") -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'HomeAndConstructionBusiness',
        name: site.nombre,
        description,
        telephone: site.telefonoLink,
        address: {
          '@type': 'PostalAddress',
          streetAddress: site.direccion,
          addressLocality: 'Las Lagunas de Mijas',
          postalCode: '29651',
          addressRegion: 'Málaga',
          addressCountry: 'ES'
        },
        areaServed: 'Mijas, Fuengirola, Costa del Sol',
        openingHours: 'Mo-Fr 07:30-13:30,16:00-19:30'
      })}
    />
  </head>
  <body>
    <slot />

    <script>
      // Revela secciones al entrar en viewport (sin librerías)
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Salpicadura al clicar/tocar (v4, fina): SIN mancha grande.
      // Solo gotitas pequeñas y nítidas que se dispersan en arco y caen con
      // gravedad (Web Animations API), desvaneciéndose enseguida. Discreto.
      // Respeta prefers-reduced-motion y limita ráfagas simultáneas.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const COLORES = ['#d2262b', '#1a4fa8', '#efb700', '#3a7d5d', '#ffffff'];
        const rnd = (a: number, b: number) => a + Math.random() * (b - a);
        let vivos = 0;
        addEventListener('pointerdown', (e) => {
          if (vivos > 3) return;
          vivos++;
          const color = COLORES[(Math.random() * COLORES.length) | 0];
          const root = document.createElement('div');
          root.className = 'splash4';
          root.style.left = e.clientX + 'px';
          root.style.top = e.clientY + 'px';
          document.body.appendChild(root);

          const n = 11 + ((Math.random() * 5) | 0);
          for (let i = 0; i < n; i++) {
            const g = document.createElement('span');
            g.className = 'splash4__gota';
            const sz = rnd(1.6, 4.2);
            g.style.width = g.style.height = sz.toFixed(1) + 'px';
            g.style.marginLeft = g.style.marginTop = (-sz / 2).toFixed(1) + 'px';
            g.style.background = color;
            root.appendChild(g);
            const ang = rnd(0, Math.PI * 2);
            const alcance = rnd(14, 52);
            const dx = Math.cos(ang) * alcance;
            const subida = Math.sin(ang) * alcance * 0.5 - rnd(6, 22);
            const caida = rnd(16, 44);
            g.animate(
              [
                { transform: 'translate(0,0) scale(0.6)', opacity: 0.9 },
                { transform: `translate(${(dx * 0.62).toFixed(1)}px, ${subida.toFixed(1)}px) scale(1)`, opacity: 0.85, offset: 0.4 },
                { transform: `translate(${dx.toFixed(1)}px, ${caida.toFixed(1)}px) scale(0.4)`, opacity: 0 }
              ],
              {
                duration: rnd(420, 720),
                delay: rnd(0, 60),
                easing: 'cubic-bezier(.22,.61,.36,1)',
                fill: 'forwards'
              }
            );
          }

          setTimeout(() => {
            root.remove();
            vivos--;
          }, 900);
        });
      }
    </script>
  </body>
</html>
