---
import '../styles/global.css';
import { site } from '../data/site';
import { asset } from '../lib/asset';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.nombre} · Tienda de pinturas en Las Lagunas de Mijas (Málaga)`,
  description = `Tienda de pinturas en Las Lagunas de Mijas con más de 20 años: tintometría (cualquier color a medida), Bupisa, Rugoplast, esmaltes, fachadas e impermeabilización. Para particulares y pintores profesionales de la Costa del Sol.`
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={asset('/assets/favicon.png')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800&family=Inter:wght@400;500;600&family=Nanum+Brush+Script&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#d2262b" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL(asset('/assets/og.jpg'), Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(asset('/assets/og.jpg'), Astro.site)} />

    <!-- Datos estructurados: comercio local (SEO "tienda de pinturas Mijas") -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'HomeAndConstructionBusiness',
        name: site.nombre,
        description,
        telephone: site.telefonoLink,
        address: {
          '@type': 'PostalAddress',
          streetAddress: site.direccion,
          addressLocality: 'Las Lagunas de Mijas',
          postalCode: '29651',
          addressRegion: 'Málaga',
          addressCountry: 'ES'
        },
        areaServed: 'Mijas, Fuengirola, Costa del Sol',
        openingHours: 'Mo-Fr 07:30-13:30,16:00-19:30'
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-full bg-white px-4 py-2 text-[13px] font-bold text-negro focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-100"
    >
      Saltar al contenido
    </a>
    <slot />

    <script>
      // Revela secciones al entrar en viewport (sin librerías)
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Salpicadura al clicar/tocar (v5): mini-mancha REAL (sprite de
      // salpicadura auténtica teñida, pequeña y discreta) + gotitas finas que
      // se dispersan con gravedad (WAAPI). Respeta prefers-reduced-motion.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
        const COLORES: Record<string, string> = {
          rojo: '#d2262b',
          azul: '#1a4fa8',
          albero: '#efb700',
          blanco: '#f5f0e6'
        };
        const NOMBRES = Object.keys(COLORES);
        const rnd = (a: number, b: number) => a + Math.random() * (b - a);
        let vivos = 0;
        addEventListener('pointerdown', (e) => {
          if (vivos > 3) return;
          vivos++;
          const nombre = NOMBRES[(Math.random() * NOMBRES.length) | 0];
          const root = document.createElement('div');
          root.className = 'splash5';
          root.style.left = e.clientX + 'px';
          root.style.top = e.clientY + 'px';
          document.body.appendChild(root);

          // mini salpicadura real (silueta auténtica, tamaño discreto)
          const img = document.createElement('img');
          img.className = 'splash5__sprite';
          img.src = `${BASE}/assets/manchas/splat${2 + ((Math.random() * 2) | 0)}-${nombre}.png`;
          img.alt = '';
          const s = rnd(34, 54);
          img.style.width = s.toFixed(0) + 'px';
          img.style.left = (-s / 2).toFixed(0) + 'px';
          img.style.top = (-s / 2).toFixed(0) + 'px';
          root.appendChild(img);
          img.animate(
            [
              { transform: `scale(0.3) rotate(${(Math.random() * 360) | 0}deg)`, opacity: 0.85 },
              { transform: `scale(1) rotate(${(Math.random() * 360) | 0}deg)`, opacity: 0.7, offset: 0.25 },
              { transform: 'scale(1.04)', opacity: 0 }
            ],
            { duration: 900, easing: 'cubic-bezier(.2,.9,.3,1)', fill: 'forwards' }
          );

          const n = 7 + ((Math.random() * 4) | 0);
          for (let i = 0; i < n; i++) {
            const g = document.createElement('span');
            g.className = 'splash5__gota';
            const sz = rnd(1.6, 4);
            g.style.width = g.style.height = sz.toFixed(1) + 'px';
            g.style.marginLeft = g.style.marginTop = (-sz / 2).toFixed(1) + 'px';
            g.style.background = COLORES[nombre];
            root.appendChild(g);
            const ang = rnd(0, Math.PI * 2);
            const alcance = rnd(16, 54);
            const dx = Math.cos(ang) * alcance;
            const subida = Math.sin(ang) * alcance * 0.5 - rnd(6, 20);
            const caida = rnd(16, 42);
            g.animate(
              [
                { transform: 'translate(0,0) scale(0.6)', opacity: 0.9 },
                { transform: `translate(${(dx * 0.62).toFixed(1)}px, ${subida.toFixed(1)}px) scale(1)`, opacity: 0.85, offset: 0.4 },
                { transform: `translate(${dx.toFixed(1)}px, ${caida.toFixed(1)}px) scale(0.4)`, opacity: 0 }
              ],
              { duration: rnd(420, 700), delay: rnd(0, 60), easing: 'cubic-bezier(.22,.61,.36,1)', fill: 'forwards' }
            );
          }

          setTimeout(() => {
            root.remove();
            vivos--;
          }, 1000);
        });
      }
    </script>
  </body>
</html>
