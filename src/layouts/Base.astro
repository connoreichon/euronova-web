---
import '../styles/global.css';
import { site } from '../data/site';
import { asset } from '../lib/asset';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.nombre} · Tienda de pinturas en Las Lagunas de Mijas (Málaga)`,
  description = `Tienda de pinturas en Las Lagunas de Mijas con más de 20 años: tintometría (cualquier color a medida), Bupisa, Rugoplast, esmaltes, fachadas e impermeabilización. Para particulares y pintores profesionales de la Costa del Sol.`
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={asset('/assets/logo.svg')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Inter:wght@400;500;600&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#d2262b" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary" />

    <!-- Datos estructurados: comercio local (SEO "tienda de pinturas Mijas") -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'HomeAndConstructionBusiness',
        name: site.nombre,
        description,
        telephone: site.telefonoLink,
        address: {
          '@type': 'PostalAddress',
          streetAddress: site.direccion,
          addressLocality: 'Las Lagunas de Mijas',
          postalCode: '29651',
          addressRegion: 'Málaga',
          addressCountry: 'ES'
        },
        areaServed: 'Mijas, Fuengirola, Costa del Sol',
        openingHours: 'Mo-Fr 07:30-13:30,16:00-19:30'
      })}
    />
  </head>
  <body>
    <slot />

    <script>
      // Revela secciones al entrar en viewport (sin librerías)
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Splash de pintura al clicar/tocar: mancha breve bajo el puntero.
      // Colores de la marca; respeta prefers-reduced-motion; máx. 1 cada 120 ms.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const colores = ['#d2262b', '#2a5cad', '#d9a441', '#5f6b3a'];
        const SPLAT =
          'M52 8c6 0 9 6 14 8s13-1 16 5-3 10-2 16 8 9 6 15-9 5-13 9-4 12-11 13-9-6-15-7-13 4-17-2 2-11 0-17S18 38 20 31s10-4 14-8 4-11 11-13c3-1 5-2 7-2z';
        let last = 0;
        addEventListener('pointerdown', (e) => {
          const now = Date.now();
          if (now - last < 120) return;
          last = now;
          const c = colores[Math.floor(Math.random() * colores.length)];
          const el = document.createElement('div');
          el.className = 'splash';
          el.style.left = e.clientX + 'px';
          el.style.top = e.clientY + 'px';
          el.style.setProperty('--rot', Math.floor(Math.random() * 360) + 'deg');
          el.innerHTML =
            `<svg viewBox="0 0 104 104" fill="${c}" aria-hidden="true">` +
            `<path d="${SPLAT}"/>` +
            `<circle cx="14" cy="22" r="4"/><circle cx="92" cy="30" r="3"/>` +
            `<circle cx="88" cy="86" r="5"/><circle cx="18" cy="88" r="3"/>` +
            `</svg>`;
          document.body.appendChild(el);
          el.addEventListener('animationend', () => el.remove());
        });
      }
    </script>
  </body>
</html>
