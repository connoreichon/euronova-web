---
import '../styles/global.css';
import { site } from '../data/site';
import { asset } from '../lib/asset';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.nombre} · Tienda de pinturas en Las Lagunas de Mijas (Málaga)`,
  description = `Tienda de pinturas en Las Lagunas de Mijas con más de 20 años: tintometría (cualquier color a medida), Bupisa, Rugoplast, esmaltes, fachadas e impermeabilización. Para particulares y pintores profesionales de la Costa del Sol.`
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={asset('/assets/favicon.png')} />
    <link rel="apple-touch-icon" href={asset('/assets/apple-touch-icon.png')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800&family=Inter:wght@400;500;600&family=Nanum+Brush+Script&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#d2262b" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL(asset('/assets/og.jpg'), Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(asset('/assets/og.jpg'), Astro.site)} />

    <!-- Datos estructurados: comercio local (SEO "tienda de pinturas Mijas") -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'HardwareStore',
        name: site.nombre,
        legalName: site.razonSocial,
        description,
        image: new URL(asset('/assets/og.jpg'), Astro.site).href,
        url: Astro.site?.href,
        telephone: site.telefonoLink,
        email: site.email,
        priceRange: '€€',
        currenciesAccepted: 'EUR',
        address: {
          '@type': 'PostalAddress',
          streetAddress: site.direccion,
          addressLocality: 'Las Lagunas de Mijas',
          postalCode: '29651',
          addressRegion: 'Málaga',
          addressCountry: 'ES'
        },
        areaServed: ['Mijas', 'Fuengirola', 'Costa del Sol'],
        sameAs: [site.redes.instagram, site.redes.facebook],
        openingHoursSpecification: {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '07:30',
          closes: '19:30'
        },
        makesOffer: [
          'Pintura para interior',
          'Pintura para fachadas',
          'Esmaltes',
          'Barnices y protección de madera',
          'Pintura para suelos',
          'Impermeabilización',
          'Color a medida (tintometría)'
        ]
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-full bg-white px-4 py-2 text-[13px] font-bold text-negro focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-100"
    >
      Saltar al contenido
    </a>
    <slot />

    <script>
      // Habilita las animaciones basadas en JS (sin JS todo se ve completo).
      document.documentElement.classList.add('js-anim');
      const reduceUI = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // --- Barra de progreso "de pintura" al hacer scroll ---
      if (!reduceUI) {
        const bar = document.createElement('div');
        bar.className = 'scroll-progress';
        document.body.appendChild(bar);
        let t = false;
        const upd = () => {
          t = false;
          const h = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.transform = `scaleX(${h > 0 ? Math.min(window.scrollY / h, 1) : 0})`;
        };
        addEventListener('scroll', () => { if (!t) { t = true; requestAnimationFrame(upd); } }, { passive: true });
        upd();
      }

      // --- Reveals (+ imágenes) y rótulos a brocha al entrar en viewport ---
      const els = document.querySelectorAll('.reveal, .reveal-img');
      const kickers = document.querySelectorAll('.kicker-brocha');
      const nums = document.querySelectorAll('[data-count]');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));

        const ioBrocha = new IntersectionObserver(
          (entries) => {
            for (const e of entries) if (e.isIntersecting) { e.target.classList.add('pintado'); ioBrocha.unobserve(e.target); }
          },
          { threshold: 0.6 }
        );
        kickers.forEach((el) => ioBrocha.observe(el));

        // Contador animado (easing suave hasta el número final)
        const ioNum = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              const el = e.target as HTMLElement;
              ioNum.unobserve(el);
              const to = parseInt(el.dataset.count || '0', 10);
              if (reduceUI) { el.textContent = String(to); continue; }
              let t0: number | null = null;
              const tick = (now: number) => {
                if (t0 === null) t0 = now;
                const k = Math.min((now - t0) / 1100, 1);
                el.textContent = String(Math.round(to * (1 - Math.pow(1 - k, 3))));
                if (k < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            }
          },
          { threshold: 0.6 }
        );
        nums.forEach((el) => ioNum.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
        kickers.forEach((el) => el.classList.add('pintado'));
        nums.forEach((el) => { (el as HTMLElement).textContent = (el as HTMLElement).dataset.count || ''; });
      }

      // --- Entrada escalonada del hero al cargar ---
      const heroAnim = document.querySelector('.hero-anim');
      if (heroAnim) setTimeout(() => heroAnim.classList.add('play'), 60);

      // --- Parallax suave de imágenes marcadas ---
      if (!reduceUI) {
        const plx = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
        if (plx.length) {
          let t2 = false;
          const updP = () => {
            t2 = false;
            const vh = window.innerHeight;
            for (const el of plx) {
              const r = el.getBoundingClientRect();
              const mid = r.top + r.height / 2 - vh / 2;
              const f = parseFloat(el.dataset.parallax || '0.08');
              el.style.setProperty('--py', `${(-mid * f).toFixed(1)}px`);
            }
          };
          addEventListener('scroll', () => { if (!t2) { t2 = true; requestAnimationFrame(updP); } }, { passive: true });
          updP();
        }
      }
    </script>

    <script>
      // ---- Pincelada al clicar + cursor brocha ----
      const reduceMov = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const BASE_URL = import.meta.env.BASE_URL.replace(/\/$/, '');

      // Luminancia del fondo bajo un elemento (para elegir tinta roja o negra).
      const lin = (v: number) => {
        v /= 255;
        return v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
      };
      const luminancia = (r: number, g: number, b: number) =>
        0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
      const fondoDe = (el: HTMLElement | null): [number, number, number] => {
        while (el && el !== document.documentElement) {
          const c = getComputedStyle(el).backgroundColor;
          const m = c.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
          if (m && (m[4] === undefined || parseFloat(m[4]) > 0.3)) return [+m[1], +m[2], +m[3]];
          el = el.parentElement;
        }
        return [23, 17, 17]; // negro de marca por defecto
      };
      // Fondo claro o rojo → tinta NEGRA; fondo oscuro → tinta ROJA de marca.
      const fondoClaro = (el: HTMLElement | null) => {
        const [r, g, b] = fondoDe(el);
        return luminancia(r, g, b) >= 0.12;
      };

      // Splash de pintura reutilizable (corazones de favoritos, etc.): una
      // salpicadura real de marca florece y se disuelve en el punto (x, y).
      (window as any).euronovaSplash = (x: number, y: number, color?: string) => {
        if (reduceMov) return;
        const tinta = color || 'rojo';
        const splat = document.createElement('img');
        splat.className = 'mancha-click';
        splat.src = `${BASE_URL}/assets/manchas/splat${Math.random() < 0.5 ? 2 : 3}-${tinta}.png`;
        splat.alt = '';
        const w = 86 + Math.random() * 26;
        splat.style.left = x + 'px';
        splat.style.top = y + 'px';
        splat.style.width = w.toFixed(0) + 'px';
        const rot = (Math.random() * 50 - 25).toFixed(0);
        const base = `translate(-50%,-50%) rotate(${rot}deg)`;
        document.body.appendChild(splat);
        splat.animate(
          [
            { transform: base + ' scale(0.3)', opacity: 0.95, offset: 0 },
            { transform: base + ' scale(1.04)', opacity: 0.9, offset: 0.45 },
            { transform: base + ' scale(1.12)', opacity: 0, offset: 1 }
          ],
          { duration: 520, easing: 'cubic-bezier(.2,.7,.3,1)', fill: 'forwards' }
        );
        // Gotitas que saltan
        const dotColor = tinta === 'blanco' ? '#f6f1e7' : '#d2262b';
        for (let i = 0; i < 3; i++) {
          const d = document.createElement('span');
          d.className = 'mancha-click';
          const s = 4 + Math.random() * 5;
          d.style.cssText = `left:${x}px;top:${y}px;width:${s}px;height:${s}px;border-radius:9999px;background:${dotColor};`;
          document.body.appendChild(d);
          const ang = Math.random() * Math.PI * 2;
          const dist = 26 + Math.random() * 26;
          d.animate(
            [
              { transform: 'translate(-50%,-50%)', opacity: 0.9 },
              {
                transform: `translate(calc(-50% + ${(Math.cos(ang) * dist).toFixed(0)}px), calc(-50% + ${(Math.sin(ang) * dist + 10).toFixed(0)}px)) scale(0.6)`,
                opacity: 0
              }
            ],
            { duration: 430 + Math.random() * 120, easing: 'cubic-bezier(.2,.6,.4,1)', fill: 'forwards' }
          );
          setTimeout(() => d.remove(), 620);
        }
        setTimeout(() => splat.remove(), 560);
      };

      // Al clicar, se PINTA un trazo de brocha (textura real) donde pinchas: el
      // trazo se "pinta" con un barrido a lo largo (clip-path) y luego se
      // disuelve solo. Respeta prefers-reduced-motion.
      // Solo con puntero fino (ratón): en táctil no hay cursor-brocha, así que la
      // salpicadura sería ruido en cada toque. Coherente con el cursor.
      if (!reduceMov && window.matchMedia('(pointer: fine)').matches) {
        const N_TRAZOS = 2;
        let vivas = 0;
        addEventListener('click', (e) => {
          if (!e.detail || vivas > 2) return; // e.detail===0 = teclado → se ignora
          // Nunca sobre controles/UI: la pincelada es un gesto sobre el contenido.
          const t = e.target as HTMLElement;
          if (t.closest('a,button,input,textarea,select,label,[role="tab"],[role="option"]')) return;
          vivas++;
          const img = document.createElement('img');
          img.className = 'mancha-click';
          // Fondo claro/rojo → trazo NEGRO (con sus luces); oscuro → trazo ROJO.
          const sufijo = fondoClaro(t) ? '-negro' : '';
          img.src = `${BASE_URL}/assets/pincel/trazo${1 + ((Math.random() * N_TRAZOS) | 0)}${sufijo}.png`;
          img.alt = '';
          const ancho = 68 + Math.random() * 60; // 68–128 px
          img.style.left = e.clientX + 'px';
          img.style.top = e.clientY + 'px';
          img.style.width = ancho.toFixed(0) + 'px';
          // Todos horizontales, mismo sentido (carga izquierda → punta seca derecha).
          const base = 'translate(-50%,-50%)';
          img.style.transform = base + ' scale(1)';
          document.body.appendChild(img);
          // Se "pinta" de la carga (izq) a la punta seca (der) con una presión
          // que rebota un pelín, y se disuelve de forma orgánica.
          img.animate(
            [
              { clipPath: 'inset(0 100% 0 0)', transform: base + ' scale(0.9)', opacity: 0.5, offset: 0 },
              { clipPath: 'inset(0 0 0 0)', transform: base + ' scale(1.03)', opacity: 1, offset: 0.32 },
              { clipPath: 'inset(0 0 0 0)', transform: base + ' scale(1)', opacity: 1, offset: 0.52 },
              { clipPath: 'inset(0 0 0 0)', transform: base + ' scale(1)', opacity: 0, offset: 1 }
            ],
            { duration: 640, easing: 'cubic-bezier(.2,.7,.3,1)', fill: 'forwards' }
          );
          setTimeout(() => {
            img.remove();
            vivas--;
          }, 660);
        });
      }

      // Cursor brocha (solo con puntero fino = ratón; en táctil no hay cursor).
      // Dos capas: punta ROJA (fondos oscuros) y punta NEGRA (fondos rojos/claros),
      // con fundido entre ambas según el fondo bajo el cursor.
      if (window.matchMedia('(pointer: fine)').matches) {
        document.documentElement.classList.add('js-brush', 'pointer-fino');
        const cont = document.createElement('div');
        cont.className = 'brocha-cursor';
        const wrap = document.createElement('span');
        wrap.className = 'brocha-cursor__wrap';
        const imgA = document.createElement('img');
        imgA.className = 'brocha-cursor__img brocha-cursor__img--roja';
        imgA.src = `${BASE_URL}/assets/pincel/brocha-cursor.png`;
        imgA.alt = '';
        const imgB = document.createElement('img');
        imgB.className = 'brocha-cursor__img brocha-cursor__img--negra';
        imgB.src = `${BASE_URL}/assets/pincel/brocha-cursor-negra.png`;
        imgB.alt = '';
        wrap.appendChild(imgA);
        wrap.appendChild(imgB);
        cont.appendChild(wrap);
        document.body.appendChild(cont);
        const TIPX = 0.01,
          TIPY = 0.01; // la punta está en la esquina superior izquierda exacta
        let mx = -200,
          my = -200,
          raf = 0,
          visible = false;
        const pintar = () => {
          raf = 0;
          const w = wrap.offsetWidth || 46;
          const h = wrap.offsetHeight || 45;
          cont.style.transform = `translate(${(mx - w * TIPX).toFixed(1)}px, ${(my - h * TIPY).toFixed(1)}px)`;
        };
        window.addEventListener('mousemove', (e) => {
          mx = e.clientX;
          my = e.clientY;
          if (!visible) {
            cont.classList.add('visible');
            visible = true;
          }
          if (!raf) raf = requestAnimationFrame(pintar);
        });
        window.addEventListener('mousedown', () => cont.classList.add('pressing'));
        window.addEventListener('mouseup', () => cont.classList.remove('pressing'));
        document.addEventListener('mouseleave', () => cont.classList.remove('visible'));
        document.addEventListener('mouseenter', () => {
          if (mx > -100) cont.classList.add('visible');
        });
        document.addEventListener('mouseover', (e) => {
          const t = e.target as HTMLElement;
          // Sobre campos de texto, oculta la brocha (ahí manda el I-beam).
          cont.classList.toggle('oculta', !!t.closest('input,textarea,select,[contenteditable]'));
          // La punta cambia de tinta según el fondo (roja en oscuro, negra en rojo/claro).
          cont.classList.toggle('tinta-negra', fondoClaro(t));
        });
      }
    </script>
  </body>
</html>
