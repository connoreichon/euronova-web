---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Mancha from '../components/Mancha.astro';
import { site } from '../data/site';
import { RAL, NCS, EUROTREND } from '../data/cartas';
import { asset } from '../lib/asset';

const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
  'Hola, me gustaría hacer una consulta sobre un color: '
)}`;

const cartas = [
  { id: 'ral', nombre: 'RAL', sub: 'Carta clásica · ' + RAL.length + ' colores', colores: RAL },
  { id: 'ncs', nombre: 'NCS', sub: 'Selección de los más pedidos', colores: NCS },
  { id: 'eurotrend', nombre: 'EUROTREND', sub: 'Muy pronto en la web', colores: EUROTREND }
];
---

<Base
  title={`Cartas de colores RAL, NCS y Eurotrend · ${site.nombre} (Mijas)`}
  description="Consulta online las cartas de colores RAL, NCS y Eurotrend de Pinturas Euronova en Las Lagunas de Mijas: busca tu color por código y pídelo mezclado a medida en tienda."
>
  <Header />
  <main class="pt-16 md:pt-20">
    <section class="relative overflow-hidden bg-negro py-14 text-papel md:py-20">
      <Mancha color="rojo" forma={1} class="-top-14 -right-20 w-64 opacity-30 md:w-80" rotar={60} />
      <div class="container-x">
        <p class="kicker-brocha text-rojo">Cartas de colores</p>
        <h1 class="display mt-2 max-w-2xl text-3xl text-white md:text-5xl">
          Busca tu color por código,<br />como en el mostrador.
        </h1>
        <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-papel/70">
          Elige la carta, escribe el código o el nombre y encuentra tu color.
          Lo mezclamos al momento con la tintometría de la tienda.
        </p>
        <p class="mt-3 max-w-xl text-[12.5px] text-papel/45">
          ⚠ El color en pantalla es orientativo: cada monitor lo muestra distinto.
          La referencia válida es siempre la carta física en tienda.
        </p>

        <!-- Selector de carta -->
        <div class="mt-8 flex flex-wrap gap-2.5" role="tablist" aria-label="Elige una carta de colores">
          {
            cartas.map((carta, i) => (
              <button
                type="button"
                role="tab"
                id={`tab-${carta.id}`}
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`panel-${carta.id}`}
                data-carta={carta.id}
                class={`tab-carta cursor-pointer rounded-full px-5 py-2.5 text-[13px] font-bold transition-colors ${
                  i === 0 ? 'bg-rojo text-white' : 'bg-white/10 text-papel hover:bg-white/20'
                }`}
              >
                {carta.nombre}
                <span class="ml-1.5 hidden text-[11px] font-normal opacity-70 sm:inline">{carta.sub}</span>
              </button>
            ))
          }
        </div>

        <!-- Buscador -->
        <div class="mt-5 max-w-md">
          <label for="buscador" class="sr-only">Buscar color por código o nombre</label>
          <div class="flex items-center gap-2.5 rounded-full border border-white/20 bg-white/8 px-5 py-3 transition-colors focus-within:border-rojo">
            <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 shrink-0 text-papel/60" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="7" />
              <path d="m20 20-3.8-3.8" stroke-linecap="round" />
            </svg>
            <input
              id="buscador"
              type="search"
              placeholder="Ej.: 7016, blanco perla, 0502…"
              autocomplete="off"
              class="w-full bg-transparent text-[14px] text-white placeholder:text-papel/40 focus:outline-none"
            />
          </div>
          <p id="resultado-info" class="mt-2 pl-2 text-[12px] text-papel/50" aria-live="polite"></p>
        </div>
      </div>
    </section>

    <!-- Rejillas de colores -->
    <section class="bg-negro py-10 md:py-14">
      <div class="container-x">
        {
          cartas.map((carta, i) => (
            <div
              id={`panel-${carta.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${carta.id}`}
              data-panel={carta.id}
              class={i === 0 ? '' : 'hidden'}
            >
              {carta.colores.length ? (
                <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
                  {carta.colores.map((color) => (
                    <div
                      class="color-item overflow-hidden rounded-xl bg-white/5"
                      data-buscar={`${color.c} ${color.n}`.toLowerCase()}
                    >
                      <div class="aspect-[4/3]" style={`background-color:${color.h};`} />
                      <div class="px-3 py-2.5">
                        <p class="text-[12.5px] font-bold text-white">{color.c}</p>
                        <p class="truncate text-[11.5px] text-papel/60">{color.n}</p>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="rounded-2xl border border-white/12 px-8 py-14 text-center">
                  <p class="font-display text-xl font-bold text-white">
                    La carta Eurotrend está de camino
                  </p>
                  <p class="mx-auto mt-2 max-w-md text-[14px] text-papel/60">
                    La estamos digitalizando. Mientras tanto la tienes completa en el
                    mostrador de la tienda — o pregúntanos por WhatsApp.
                  </p>
                  <a
                    href={wa}
                    target="_blank"
                    rel="noopener"
                    class="mt-6 inline-flex items-center gap-2 rounded-full bg-wasap px-6 py-3 text-[13px] font-bold text-white transition-transform hover:scale-105"
                  >
                    Preguntar por un color Eurotrend
                  </a>
                </div>
              )}
            </div>
          ))
        }
        <p id="sin-resultados" class="hidden py-14 text-center text-[14px] text-papel/60">
          No encontramos ese código en esta carta. Prueba en otra pestaña o
          <a href={wa} target="_blank" rel="noopener" class="font-bold text-rojo underline-offset-4 hover:underline">pregúntanos por WhatsApp</a> — en tienda hay miles más.
        </p>
      </div>
    </section>

    <!-- Enlace a los blancos rotos (viven en la tintometría de la portada) -->
    <section class="bg-negro py-12 md:py-16">
      <div class="container-x flex flex-wrap items-center justify-between gap-4">
        <p class="max-w-md text-[14px] leading-relaxed text-papel/70">
          ¿Buscas un blanco roto de moda? Tenemos los favoritos del mostrador
          seleccionados en la sección de tintometría.
        </p>
        <a
          href={asset('/') + '#color'}
          class="inline-flex items-center gap-2 rounded-full bg-rojo px-6 py-3 text-[13px] font-bold text-white transition-transform hover:scale-105"
        >
          Ver blancos rotos
          <svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloat />
</Base>

<script>
  // Pestañas de carta + buscador por código/nombre (sin librerías)
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-carta');
  const paneles = document.querySelectorAll<HTMLElement>('[data-panel]');
  const buscador = document.getElementById('buscador') as HTMLInputElement;
  const info = document.getElementById('resultado-info');
  const sinResultados = document.getElementById('sin-resultados');
  let activa = 'ral';

  const filtrar = () => {
    const q = buscador.value.trim().toLowerCase();
    const panel = document.querySelector<HTMLElement>(`[data-panel="${activa}"]`);
    if (!panel) return;
    const items = panel.querySelectorAll<HTMLElement>('.color-item');
    let visibles = 0;
    items.forEach((el) => {
      const coincide = !q || (el.dataset.buscar ?? '').includes(q);
      el.classList.toggle('hidden', !coincide);
      if (coincide) visibles++;
    });
    if (info) {
      info.textContent = q
        ? `${visibles} color${visibles === 1 ? '' : 'es'} en la carta ${activa.toUpperCase()}`
        : '';
    }
    sinResultados?.classList.toggle('hidden', visibles > 0 || items.length === 0);
  };

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      activa = tab.dataset.carta ?? 'ral';
      tabs.forEach((t) => {
        const sel = t === tab;
        t.setAttribute('aria-selected', String(sel));
        t.classList.toggle('bg-rojo', sel);
        t.classList.toggle('text-white', sel);
        t.classList.toggle('bg-white/10', !sel);
        t.classList.toggle('text-papel', !sel);
      });
      paneles.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== activa));
      filtrar();
    });
  });
  buscador?.addEventListener('input', filtrar);
</script>
